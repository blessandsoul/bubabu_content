{
  "id": "EHW_DI6sm80",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 0.08,
      "duration": 6.56,
      "text": "მაშინ მქონოდა წითელი და გადავცვალე"
    },
    {
      "start": 2.919,
      "duration": 3.721,
      "text": "ხილებში ეულა"
    },
    {
      "start": 6.799,
      "duration": 7.04,
      "text": "დაშევრცებოშვილებში"
    },
    {
      "start": 9.559,
      "duration": 7.16,
      "text": "თქვენჰეჰე რა მაგარია რა მაგარია სად"
    },
    {
      "start": 13.839,
      "duration": 2.88,
      "text": "გარბიხარ კაცო"
    },
    {
      "start": 19.439,
      "duration": 9.121,
      "text": "დალოდე ე ე ვაი"
    },
    {
      "start": 23.519,
      "duration": 5.041,
      "text": "ვაი მივალ რატომ ალბათ ვიბოდები"
    },
    {
      "start": 29.039,
      "duration": 3.881,
      "text": "ვაი ვა"
    },
    {
      "start": 33.47,
      "duration": 7.45,
      "text": "[მუსიკა]"
    },
    {
      "start": 35.64,
      "duration": 10.52,
      "text": "რა მოი მოიცადექოქო ე"
    },
    {
      "start": 40.92,
      "duration": 5.24,
      "text": "უი უი აღარ ისმის"
    },
    {
      "start": 46.92,
      "duration": 6.08,
      "text": "მეგობრებო მგონი ჩემი ლეპტოპი აღარ"
    },
    {
      "start": 49.559,
      "duration": 7.361,
      "text": "მუშაობს ჩემი მანქანის ელემენტები დაჯდა"
    },
    {
      "start": 53.0,
      "duration": 6.96,
      "text": "ვეღარ დადის უფ ჰა ჰო, ყველაფერი"
    },
    {
      "start": 56.92,
      "duration": 6.4,
      "text": "ერთდროულად გაფუჭდა. ეჰ, რა კარგი დღე"
    },
    {
      "start": 59.96,
      "duration": 6.72,
      "text": "გვქონდა და ყველაფერი ჩაიშალა. მოდი იცი"
    },
    {
      "start": 63.32,
      "duration": 6.24,
      "text": "რა ვქნათ? მე ახლა წავალ დიდ პარკს"
    },
    {
      "start": 66.68,
      "duration": 5.4,
      "text": "მოვიტან, ეს ყველაფერი შიქ ჩავდოთ და"
    },
    {
      "start": 69.56,
      "duration": 7.0,
      "text": "გადავყაროთ. მაინც გაფუჭებულია და რაღად"
    },
    {
      "start": 72.08,
      "duration": 6.039,
      "text": "გვინდა. პიო, მოიცა, ამის გადაყრა არ"
    },
    {
      "start": 76.56,
      "duration": 3.4,
      "text": "შეიძლება."
    },
    {
      "start": 78.119,
      "duration": 5.281,
      "text": "რატომ?"
    },
    {
      "start": 79.96,
      "duration": 6.799,
      "text": "იმიტომ, რომ ნარჩენი ნაგავი არ არის."
    },
    {
      "start": 83.4,
      "duration": 5.56,
      "text": "საბურავი, ელემენტი, ლეპტოპი, ყურსასმენი,"
    },
    {
      "start": 86.759,
      "duration": 4.32,
      "text": "ნათურები, ტელეფონის დამტენი და სხვა"
    },
    {
      "start": 88.96,
      "duration": 4.92,
      "text": "ელექტრონარჩენები ნაგავში არ უნდა"
    },
    {
      "start": 91.079,
      "duration": 4.801,
      "text": "გადაყარო, ისინი უნდა გადაამუშავო და"
    },
    {
      "start": 93.88,
      "duration": 4.8,
      "text": "განაახლო"
    },
    {
      "start": 95.88,
      "duration": 5.879,
      "text": "შოზე, გადამუშავება რას ნიშნავს?"
    },
    {
      "start": 98.68,
      "duration": 7.759,
      "text": "აგვიხსენი რა. აბა, ყურადღებით"
    },
    {
      "start": 101.759,
      "duration": 6.761,
      "text": "მომისმინეთ. დრო არასდროს ჩერდება, მეტიც"
    },
    {
      "start": 106.439,
      "duration": 6.841,
      "text": "არც კი ნელდება."
    },
    {
      "start": 108.52,
      "duration": 7.72,
      "text": "სხვას ყველაფერს აძველებს, თვითონ კი არ"
    },
    {
      "start": 113.28,
      "duration": 6.759,
      "text": "ძველდება. ჩვენი ძველი"
    },
    {
      "start": 116.24,
      "duration": 8.04,
      "text": "ნივთების მუშაობა ძნელდება."
    },
    {
      "start": 120.039,
      "duration": 6.0,
      "text": "ხან მანქანა ჩერდება, ხან ეკრანი"
    },
    {
      "start": 124.28,
      "duration": 3.479,
      "text": "ბნელდება."
    },
    {
      "start": 126.039,
      "duration": 5.681,
      "text": "ესი"
    },
    {
      "start": 127.759,
      "duration": 9.641,
      "text": "სათამაშოა, მუდამ გვერდით ვინც გყავდა."
    },
    {
      "start": 131.72,
      "duration": 7.64,
      "text": "იყო ჩემი ერთგული, მეც ძალიან მიყვარდა."
    },
    {
      "start": 137.4,
      "duration": 4.839,
      "text": "მასზე ზრუნვა"
    },
    {
      "start": 139.36,
      "duration": 5.68,
      "text": "იცოდე, ახლა შენ"
    },
    {
      "start": 142.239,
      "duration": 7.761,
      "text": "გევალება იქნება არ"
    },
    {
      "start": 145.04,
      "duration": 9.36,
      "text": "გენანება, მაგრამ ხომ გერალება, ძველი"
    },
    {
      "start": 150.0,
      "duration": 4.4,
      "text": "ნივთები ნაკავში არ"
    },
    {
      "start": 155.72,
      "duration": 4.879,
      "text": "ჩაყარო, ჩვენი კარგი"
    },
    {
      "start": 158.8,
      "duration": 6.56,
      "text": "სამყარო,"
    },
    {
      "start": 160.599,
      "duration": 7.72,
      "text": "გავუფრთხილდეთ და ყველამ ერთად დავიცვათ"
    },
    {
      "start": 165.36,
      "duration": 5.56,
      "text": "ჩვენი გარემო"
    },
    {
      "start": 168.319,
      "duration": 5.521,
      "text": "და ჩვენი და ჩვენი"
    },
    {
      "start": 170.92,
      "duration": 8.72,
      "text": "დედამიწა და რომ"
    },
    {
      "start": 173.84,
      "duration": 7.36,
      "text": "დედამიწა სახლი ჩემი და შენი არ აირსოს"
    },
    {
      "start": 179.64,
      "duration": 5.679,
      "text": "ხელამდე"
    },
    {
      "start": 181.2,
      "duration": 7.119,
      "text": "სახიფათონა არჩენით ჩვენი ძველი"
    },
    {
      "start": 185.319,
      "duration": 8.64,
      "text": "ნივთებით ვიდრე"
    },
    {
      "start": 188.319,
      "duration": 9.48,
      "text": "ჩვენგვავნებენ მივიტანოთ სარაც მათ"
    },
    {
      "start": 193.959,
      "duration": 6.761,
      "text": "გადამუშავებენ იქ პატარა არც ეშინებათ"
    },
    {
      "start": 197.799,
      "duration": 3.721,
      "text": "და არც შეეშინდებათ"
    },
    {
      "start": 200.72,
      "duration": 2.04,
      "text": "მხოლოდ"
    },
    {
      "start": 201.52,
      "duration": 5.04,
      "text": "[მუსიკა]"
    },
    {
      "start": 202.76,
      "duration": 8.64,
      "text": "გადაქცევენ ახალ ლამაზ ნივთებო"
    },
    {
      "start": 206.56,
      "duration": 7.56,
      "text": "ხოდა მოდი მათ ახალ სიცოცხლეზე"
    },
    {
      "start": 211.4,
      "duration": 7.759,
      "text": "ვიზრუნოთ ასე"
    },
    {
      "start": 214.12,
      "duration": 7.96,
      "text": "გადავარჩინოთ და დავიბრუნოთ ჩვენი"
    },
    {
      "start": 219.159,
      "duration": 5.841,
      "text": "ნივთები ვიდრე ჩვენ"
    },
    {
      "start": 222.08,
      "duration": 5.76,
      "text": "ვეგანებენ მიგვაქვს"
    },
    {
      "start": 225.0,
      "duration": 7.04,
      "text": "ზიფსას"
    },
    {
      "start": 227.84,
      "duration": 5.8,
      "text": "გადაამუშავებენ თქვენ და მათ ახა"
    },
    {
      "start": 232.04,
      "duration": 5.6,
      "text": "სიცოცხლეზე"
    },
    {
      "start": 233.64,
      "duration": 4.0,
      "text": "ვიზრუნოთ გადავარჩინოთ"
    },
    {
      "start": 237.959,
      "duration": 7.2,
      "text": "და უკან და უკან და უკან ძველი"
    },
    {
      "start": 242.159,
      "duration": 5.72,
      "text": "ნივთები ნაკარში არ"
    },
    {
      "start": 245.159,
      "duration": 5.881,
      "text": "ჩავყაროთ"
    },
    {
      "start": 247.879,
      "duration": 5.72,
      "text": "დაზიანება ჩვენი კარგი"
    },
    {
      "start": 251.04,
      "duration": 8.439,
      "text": "სამყარო აღილდე"
    },
    {
      "start": 253.599,
      "duration": 10.961,
      "text": "დედა ყველამ ერთად დაიცვა ჩვენი"
    },
    {
      "start": 259.479,
      "duration": 5.081,
      "text": "სახემო და ჩვენი დედამისაბიდი"
    },
    {
      "start": 266.13,
      "duration": 8.079,
      "text": "[მუსიკა]"
    },
    {
      "start": 277.67,
      "duration": 3.359,
      "text": "[მუსიკა]"
    },
    {
      "start": 291.56,
      "duration": 7.0,
      "text": "უკაცრავად"
    },
    {
      "start": 294.4,
      "duration": 8.12,
      "text": "აი თურმე რა მაშ მოდი აღარ გადავყაროთ"
    },
    {
      "start": 298.56,
      "duration": 3.96,
      "text": "ჩვენი ნივთები და განვაახლოთ."
    },
    {
      "start": 307.91,
      "duration": 4.06,
      "text": "[მუსიკა]"
    },
    {
      "start": 312.919,
      "duration": 5.72,
      "text": "ხედავთ მეგობრებო, გაფუჭებული ნივთები"
    },
    {
      "start": 316.36,
      "duration": 5.36,
      "text": "გადავამუშავეთ. ახლა ჩვენც უკეთესი"
    },
    {
      "start": 318.639,
      "duration": 6.441,
      "text": "სათამაშოები გვაქვს და დედამიწაც"
    },
    {
      "start": 321.72,
      "duration": 6.599,
      "text": "კმაყოფილია. გავუფრთხილდეთ დედამიწას."
    },
    {
      "start": 325.08,
      "duration": 4.76,
      "text": "გავუფრთხილოთ დედამიწა აი ვინც დედამიწას"
    },
    {
      "start": 328.319,
      "duration": 24.961,
      "text": "უფრთხილდება"
    },
    {
      "start": 329.84,
      "duration": 26.44,
      "text": "[მუსიკა]"
    },
    {
      "start": 353.28,
      "duration": 3.0,
      "text": "კარგია"
    },
    {
      "start": 363.6,
      "duration": 14.909,
      "text": "[მუსიკა]"
    },
    {
      "start": 383.08,
      "duration": 52.33,
      "text": "เฮ เฮ"
    },
    {
      "start": 386.8,
      "duration": 48.61,
      "text": "[მუსიკა]"
    }
  ]
}