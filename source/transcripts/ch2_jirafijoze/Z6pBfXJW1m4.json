      "text": ">> გამარჯობა"
    },
    {
      "start": 88.36,
      "duration": 5.0,
      "text": ">> შენ ვინ ხარ"
    },
    {
      "start": 91.0,
      "duration": 5.64,
      "text": ">> მე გაგრინიო მქვია"
    },
    {
      "start": 93.36,
      "duration": 4.32,
      "text": ">> გაგრინიო რა მაგარი სახელია ფეხბურთი"
    },
    {
      "start": 96.64,
      "duration": 4.759,
      "text": "გიყვარს"
    },
    {
      "start": 97.68,
      "duration": 3.719,
      "text": ">> კი ძალიან"
    },
    {
      "start": 103.68,
      "duration": 6.28,
      "text": ">> რა კარგია არ გინდა ჩვენთან ერთად ითამაშო"
    },
    {
      "start": 108.04,
      "duration": 4.28,
      "text": ">> დიდი სიამოვნე ქონებით"
    },
    {
      "start": 109.96,
      "duration": 4.72,
      "text": ">> რა მაგარია ახლა თანაბრად ვიქნებით სამი"
