  "snippets": [
    {
      "start": 1.52,
      "duration": 7.52,
      "text": "მეგობრებო, მეგობრებო,"
    },
    {
      "start": 4.279,
      "duration": 4.761,
      "text": "დღეს ფეხბურთის დღეა."
    },
    {
      "start": 13.1,
      "duration": 2.02,
      "text": "[მუსიკა]"
    },
    {
      "start": 16.039,
      "duration": 3.881,
      "text": ">> ჟოზე, როგორ გელოდებოდით?"
    },
    {
      "start": 18.199,
      "duration": 3.561,
      "text": ">> ჟოზე, ფეხბურთის თამაში დავიწყოთ."
    },
    {
      "start": 19.92,
      "duration": 4.84,
      "text": "დავიწყოთ რა"
    },
    {
      "start": 21.76,
      "duration": 5.599,
      "text": ">> დავიწყოთ მე არჩევანი ვარ და ვირჩევ"
    },
    {
      "start": 24.76,
      "duration": 6.16,
      "text": "დუდუნას"
    },
    {
      "start": 27.359,
      "duration": 6.601,
      "text": ">> მე არადა ვარ და ვირჩევ მამინის"
    },
    {
      "start": 30.92,
      "duration": 8.319,
      "text": ">> მე ვირჩევ ბათუს"
    },
    {
      "start": 33.96,
      "duration": 7.0,
      "text": ">> მე ვირჩევ ე უი ჩემს გუნდში მხოლოდ ორნი"
    },
    {
      "start": 39.239,
      "duration": 4.081,
      "text": "ვიქნებით"
    },
    {
      "start": 40.96,
      "duration": 5.32,
      "text": ">> ასე მოგება გაგვიჭირდება"
    },
    {
      "start": 43.32,
      "duration": 6.2,
      "text": ">> მართალია ფეხბურთი რომ ვითამაშოთ ორივე"
    },
    {
      "start": 46.28,
      "duration": 6.959,
      "text": "გუნდში თანაბარი მოთამაშეები უნდა იყოს"
    },
    {
      "start": 49.52,
      "duration": 5.48,
      "text": "ჟოზე, ჟოზე, ჟოზე ერთი წუთით რა მოიცი"
    },
    {
      "start": 53.239,
      "duration": 4.96,
      "text": ">> გისმენ მამინი"
    },
    {
      "start": 55.0,
      "duration": 7.199,
      "text": ">> ჟოზე თანაბარი რას ნიშნავთ?"
    },
    {
      "start": 58.199,
      "duration": 6.161,
      "text": ">> თანაბარი ნიშნავს ერთნაირს აი მაგალითად"
    },
    {
      "start": 62.199,
      "duration": 4.801,
      "text": "თუ ერთ გუნდში არის სამი მოთამაშე და"
    },
    {
      "start": 64.36,
      "duration": 6.48,
      "text": "მეორეშიც არის სამი მოთამაშე ესე იგი"
    },
    {
      "start": 67.0,
      "duration": 5.64,
      "text": "მოთამაშეები თანაბრად არიან თანაბარი ანუ"
    },
    {
      "start": 70.84,
      "duration": 4.72,
      "text": "ერთმანეთის ტოლი"
    },
    {
      "start": 72.64,
      "duration": 5.92,
      "text": ">> გავიგე გავიგე თანაბრად ვიყოთ"
    },
    {
      "start": 75.56,
      "duration": 6.52,
      "text": ">> თანაბრად უნდა ვიყოთ მაგრამ ჩვენს გუნდს"
    },
    {
      "start": 78.56,
      "duration": 3.52,
      "text": "ვინ დაემა მატება"
    },
    {
      "start": 82.159,
      "duration": 4.681,
      "text": ">> უკაცრავად ეს ჩემი ბურთია"
    },
    {
      "start": 85.52,
      "duration": 2.84,
      "text": ">> გამარჯობა"
    },
    {
      "start": 86.84,
