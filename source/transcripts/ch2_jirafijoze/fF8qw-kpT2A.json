  "snippets": [
    {
      "start": 1.92,
      "duration": 4.32,
      "text": "ჟოზე"
    },
    {
      "start": 3.439,
      "duration": 3.761,
      "text": "ჟოზე გაიღვიძე"
    },
    {
      "start": 6.24,
      "duration": 4.76,
      "text": ">> ჟოზე"
    },
    {
      "start": 7.2,
      "duration": 6.92,
      "text": ">> გაიღვიძე ჟოზე ჩქარა ჩამოდი"
    },
    {
      "start": 11.0,
      "duration": 3.839,
      "text": ">> ჰ ჰა ჰა რა ხდება"
    },
    {
      "start": 14.12,
      "duration": 1.28,
      "text": ">> დაგვეხმარე"
    },
    {
      "start": 14.839,
      "duration": 2.961,
      "text": ">> ჯოზე"
    },
    {
      "start": 15.4,
      "duration": 3.959,
      "text": ">> ჟოზე ჯოზე ჟოზე ჩქარა ჩამოდიე"
    },
    {
      "start": 17.8,
      "duration": 3.76,
      "text": ">> ჯოზე დაგვეხმარე"
    },
    {
      "start": 19.359,
      "duration": 3.121,
      "text": ">> გელოდებით გელოდებით შენ როზე"
    },
    {
      "start": 21.56,
      "duration": 2.32,
      "text": ">> ჩამოდი"
    },
    {
      "start": 22.48,
      "duration": 2.4,
      "text": ">> ჩამოდი დროზე"
    },
    {
      "start": 23.88,
      "duration": 3.799,
      "text": ">> ჩელოდებით ეზოში ჩადი"
    },
    {
      "start": 24.88,
      "duration": 3.799,
      "text": ">> გელოდებით დროზე"
    },
    {
      "start": 27.679,
      "duration": 4.6,
      "text": ">> ჰა"
    },
    {
      "start": 28.679,
      "duration": 5.321,
      "text": ">> მოვდივარ ვარ"
    },
    {
      "start": 32.279,
      "duration": 4.521,
      "text": ">> აბა რა ხდება"
    },
    {
      "start": 34.0,
      "duration": 6.96,
      "text": ">> ბურთით თამაში გვინდა და სტადიონზე ვერ"
    },
    {
      "start": 36.8,
      "duration": 5.64,
      "text": "მივდივართ მთელი ეზო ბრაზიანი ვირუსებითაა"
    },
    {
      "start": 40.96,
      "duration": 3.96,
      "text": "სავსე"
    },
    {
      "start": 42.44,
      "duration": 7.72,
      "text": ">> ბრაზიანი ვირუსებით"
    },
    {
      "start": 44.92,
      "duration": 5.24,
      "text": "ხო ჰო ბრაზიანი ვირუსებია ძალიან ბრაზიანი"
    },
    {
      "start": 52.78,
      "duration": 4.939,
      "text": "[მუსიკა]"
    },
    {
      "start": 55.0,
      "duration": 3.96,
      "text": ">> ბრაზიანმა ვირუსებმა თამაშში ხელი არ უნდა"
    },
    {
      "start": 57.719,
      "duration": 3.961,
      "text": "შეგვიშალონ"
    },
    {
      "start": 58.96,
      "duration": 4.84,
      "text": "წავიდეთ სტადიონზე, მაგრამ თავი უნდა"
    },
    {
      "start": 61.68,
      "duration": 5.84,
      "text": "დავიცვათ ვირუსებისგან."
    },
    {
      "start": 63.8,
      "duration": 7.4,
      "text": ">> ვირუსებისგან თავი როგორ უნდა დავიცვათ?"
    },
    {
      "start": 67.52,
      "duration": 7.72,
      "text": ">> დუდუ, ჟოზეფინა, მამინი. ვირუსებისგან"
    },
    {
      "start": 71.2,
      "duration": 4.04,
      "text": "ჩვენ ვაქცინა დაგვიცავს."
    },
    {
      "start": 75.52,
      "duration": 6.959,
      "text": ">> რაც მე სურვილს ვისრულებ, უფრო მეტი"
    },
    {
      "start": 78.799,
      "duration": 5.521,
      "text": "მინდება, ამიტომაც უფრო მეტი ძალა"
    },
    {
      "start": 82.479,
      "duration": 6.241,
      "text": "მჭირდება."
    },
    {
      "start": 84.32,
      "duration": 6.439,
      "text": "ხოდა ძალაც მეტი მაქვს და ჯავშანიც მაცრია"
    },
    {
      "start": 88.72,
      "duration": 4.439,
      "text": "როცა მიცავსაძრაუ"
    },
    {
      "start": 90.759,
      "duration": 6.561,
      "text": "ვაქცინაცია"
    },
    {
      "start": 93.159,
      "duration": 8.681,
      "text": "ეს რა მესმის რა ამბებს ყვებიან"
    },
    {
      "start": 97.32,
      "duration": 9.799,
      "text": "თითქოს გზაში ბრაზიანი ვირუსებია"
    },
    {
      "start": 101.84,
      "duration": 8.639,
      "text": "ამ დროს ჩემი მშველელი არის რა და ერთი"
    },
    {
      "start": 107.119,
      "duration": 6.481,
      "text": "გემრიელად უნდა ავიცრა"
    },
    {
      "start": 110.479,
      "duration": 7.0,
      "text": "ვიცი რა და მეხმარება ვიცი ციცრა"
    },
    {
      "start": 113.6,
      "duration": 7.799,
      "text": "დაგეხმარება აცრა მასაც დაეხმარება აცრა"
    },
    {
      "start": 117.479,
      "duration": 7.0,
      "text": "ყველას დაგვეხმარება აცრა ჩემი სუპერძალა"
    },
    {
      "start": 121.399,
      "duration": 6.801,
      "text": "აცრა შენი სუპერძალა აცრა თქვენი"
    },
    {
      "start": 124.479,
      "duration": 7.921,
      "text": "სუპერძალა აცრა ჩვენი სუპერძალა რაც"
    },
    {
      "start": 128.2,
      "duration": 8.48,
      "text": ">> მე სურვილს ვის უფრო მეტი მინდება"
    },
    {
      "start": 132.4,
      "duration": 8.68,
      "text": "ამიტომაც უფრო მეტი ძალა მჭირდება"
    },
    {
      "start": 136.68,
      "duration": 9.44,
      "text": "ხოდა ძალაც მეტი მაქვს და ჯავშანიც მაცვია"
    },
    {
      "start": 141.08,
      "duration": 5.04,
      "text": "როცა მიცასაც საცრაო ვაქცინაცია"
    },
    {
      "start": 147.08,
      "duration": 5.68,
      "text": "ვარაკო"
    },
    {
      "start": 149.76,
      "duration": 3.0,
      "text": "ვარა"
    },
    {
      "start": 152.84,
      "duration": 7.6,
      "text": ">> გეშინია ჟოზე"
    },
    {
      "start": 154.92,
      "duration": 5.52,
      "text": ">> ნუ გეშინია ვაქცინა არის ჩვენი სუპერძალა"
    },
    {
      "start": 162.92,
      "duration": 4.239,
      "text": ">> იმდელომდე"
    },
    {
      "start": 164.48,
      "duration": 7.08,
      "text": "საშიში გზებია"
    },
    {
      "start": 167.159,
      "duration": 8.72,
      "text": "რადგან გზაში ბრაზიანი ვირუსებია"
    },
    {
      "start": 171.56,
      "duration": 8.759,
      "text": "მაშ რაღაცა მიღონოთ მაინც რა"
    },
    {
      "start": 175.879,
      "duration": 7.561,
      "text": ">> რადა ერთი გემრიელად უნდა ავიცრა"
    },
    {
      "start": 180.319,
      "duration": 6.961,
      "text": "ვიცი აც რა დამეხმარება ვიცი აც რა"
    },
    {
      "start": 183.44,
      "duration": 7.76,
      "text": "დაგეხმარება აცრასაც დაეხმარება აცრა"
    },
    {
      "start": 187.28,
      "duration": 7.039,
      "text": "ყველას დაგვეხმარება აცრა ჩემი სუპერძავა"
    },
    {
      "start": 191.2,
      "duration": 6.52,
      "text": "აცრა შენი სუპერძავლა აცრა თქვენი"
    },
    {
      "start": 194.319,
      "duration": 7.92,
      "text": "სუპერძალა აცრა ჩვენი სუპერწავლა"
    },
    {
      "start": 197.72,
      "duration": 8.799,
      "text": ">> რაც მე სურვილს ვისრულებ უფრო მეტი მინდებ"
    },
    {
      "start": 202.239,
      "duration": 8.64,
      "text": "ამიტომაც უფრო მეტი ძალა მჭირდება"
    },
    {
      "start": 206.519,
      "duration": 10.8,
      "text": "ხოდა ძალაც მეტი მაქვს და ჯავშანიც მაცვია"
    },
    {
      "start": 210.879,
      "duration": 6.44,
      "text": "როცა მიცავრა ანუ ვაქცინაცია ჰოპაპაპარაპა"
    },
    {
      "start": 220.38,
      "duration": 19.059,
      "text": "[მუსიკა]"
    },
    {
      "start": 235.36,
      "duration": 4.079,
      "text": "უხ რა კარგად ვითამაშეთ"
    },
    {
      "start": 239.72,
      "duration": 4.879,
      "text": ">> კარგია ვითამაშეთ ვითამაშეთ კარგად"
    },
    {
      "start": 241.72,
      "duration": 4.0,
      "text": "ვითამაშეთ და ბევრი ვითამაშეთ რა კარგია"
    },
    {
      "start": 244.599,
      "duration": 2.441,
      "text": "თამაში"
    },
    {
      "start": 245.72,
      "duration": 3.84,
      "text": ">> მეგობრებო"
    },
    {
      "start": 247.04,
      "duration": 4.96,
      "text": "ბრაზიანი ვირუსები თამაშში და გართობაში"
    },
    {
      "start": 249.56,
      "duration": 3.959,
      "text": "ხელს ვეღარ შეგვიშლიან."
    },
    {
      "start": 252.0,
      "duration": 7.799,
      "text": "ჩვენ"
    },
    {
      "start": 253.519,
      "duration": 6.28,
      "text": "ნამდვილი ჩემპიონები ვართ. ჩემპიონი เฮ"
    },
    {
      "start": 260.61,
      "duration": 54.69,
      "text": "[მუსიკა]"
    }
