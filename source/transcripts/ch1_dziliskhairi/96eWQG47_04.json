{
  "id": "96eWQG47_04",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 6.879,
      "duration": 8.041,
      "text": "დღეს ჟირაფი ჟოზეს გულში სხვანაირად"
    },
    {
      "start": 10.679,
      "duration": 5.641,
      "text": "თბილა, რაღაც კარგზე მიანიშნებს მშვენიერი"
    },
    {
      "start": 14.92,
      "duration": 5.4,
      "text": "დილა."
    },
    {
      "start": 16.32,
      "duration": 7.68,
      "text": "საათიდან გუგულის ხმაც ლაღია და მხნია."
    },
    {
      "start": 20.32,
      "duration": 7.0,
      "text": "დღეს ჟირაფი ჟოზეფინას დაბადების დღეა."
    },
    {
      "start": 24.0,
      "duration": 6.679,
      "text": "ჟოზე რეკავს მეგობრებთან. ჩქარა, სადმე"
    },
    {
      "start": 27.32,
      "duration": 7.0,
      "text": "შევხვდეთ დავთქვათ როგორ მივულოცოთ"
    },
    {
      "start": 30.679,
      "duration": 8.641,
      "text": "ჟოზეფინას ეს დღე. შეიკრიბნენ,"
    },
    {
      "start": 34.32,
      "duration": 7.6,
      "text": "იფიქრეს და მამინიმ თქვა: მოდი გამოვუცხოთ"
    },
    {
      "start": 39.32,
      "duration": 2.88,
      "text": "ჟოზეფინას საზეიმო ტორტი."
    },
    {
      "start": 41.92,
      "duration": 3.76,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 42.2,
      "duration": 6.12,
      "text": ">> მოეწონათ იდეა და საქმეს საპატიოს"
    },
    {
      "start": 45.68,
      "duration": 6.719,
      "text": "ავალებენ სახელგანთქმულ"
    },
    {
      "start": 48.32,
      "duration": 7.36,
      "text": "ნამცხვრის მცხობელ პიოს. დაივალეს"
    },
    {
      "start": 52.399,
      "duration": 6.041,
      "text": "სხვებმაც ვიდრე მომავალ ტორტს ჭამენ იმ"
    },
    {
      "start": 55.68,
      "duration": 7.199,
      "text": "მომავლის შესაქმნელად შეაგროვონ რამე"
    },
    {
      "start": 58.44,
      "duration": 8.52,
      "text": "თქვეს და კიდეც მოიტანეს. არ ელოდით ნუთუ"
    },
    {
      "start": 62.879,
      "duration": 6.92,
      "text": "მაიმუნმა ბევრი ხილი ბოსტნეული დუდუმ და"
    },
    {
      "start": 66.96,
      "duration": 5.64,
      "text": "ჩიჩიმაც ზედმეტ სიტყვას რომ არასდროს"
    },
    {
      "start": 69.799,
      "duration": 6.881,
      "text": "იტყვის შოკოლადი მოიტანა ყოველ"
    },
    {
      "start": 72.6,
      "duration": 7.76,
      "text": "შემთხვევისთვის ჟოზემ კიდევ დანარჩენი"
    },
    {
      "start": 76.68,
      "duration": 8.0,
      "text": "ნახე როგორ ენდნენ კვერცხი ფქვილი შაქრის"
    },
    {
      "start": 80.36,
      "duration": 8.64,
      "text": "ფხვნილი რძე და ასე შემდეგ პიოს მოსწონს"
    },
    {
      "start": 84.68,
      "duration": 9.04,
      "text": "ყველაფერი თან ხელობას იქებს გამოვაცხობ"
    },
    {
      "start": 89.0,
      "duration": 8.68,
      "text": "ჩაიკვნეთთო თათებ სა ჩლიქებს. ოღონდ სანამ"
    },
    {
      "start": 93.72,
      "duration": 7.64,
      "text": "დამითვლია წონა, დოზა, ნორმა, მანამ იქნებ"
    },
    {
      "start": 97.68,
      "duration": 7.439,
      "text": "შეარჩიოთ ჩვენი ტორტის ფორმა. ეს ყოფილა"
    },
    {
      "start": 101.36,
      "duration": 8.16,
      "text": "ჩვენებური ყველა ტორტის ბედი. ძირითადად"
    },
    {
      "start": 105.119,
      "duration": 7.761,
      "text": "ან მრგვალია, ანდა ოთხკუთხედი და საკუთარ"
    },
    {
      "start": 109.52,
      "duration": 6.559,
      "text": "სტატობას თუ არაფერს ვერჩი, ეგ ფორმები"
    },
    {
      "start": 112.88,
      "duration": 6.96,
      "text": "სულ მერევა ხოლმე ერთმანეთში."
    },
    {
      "start": 116.079,
      "duration": 7.68,
      "text": "ხოდა ისე ამიღწერეთ ტორტის ყველა კიდე,"
    },
    {
      "start": 119.84,
      "duration": 8.199,
      "text": "რომ ადვილად გავიგო და დავიხსომო კიდეც."
    },
    {
      "start": 123.759,
      "duration": 8.56,
      "text": "თქვენ იფიქრეთ, მე კი უნდა მოვითო ჯერ ეს."
    },
    {
      "start": 128.039,
      "duration": 8.401,
      "text": "პიო დოზებს მიუბრუნდა, ჟოზე დანარჩენებს."
    },
    {
      "start": 132.319,
      "duration": 6.681,
      "text": "ამბობს, თუკი ავირჩიეთ ოთხკუთხედი ხედი,"
    },
    {
      "start": 136.44,
      "duration": 5.159,
      "text": "ტორტს ექნება ოთხი კუთხე და ოთხივე"
    },
    {
      "start": 139.0,
      "duration": 5.959,
      "text": "გვერდი. პასუხობენ,"
    },
    {
      "start": 141.599,
      "duration": 7.441,
      "text": "სულ ერთია, ტორტია თუ კექსი, ოთხი კუთხე"
    },
    {
      "start": 144.959,
      "duration": 6.64,
      "text": "არ გვეყოფა, რადგან ჩვენ ვართ ექვსი."
    },
    {
      "start": 149.04,
      "duration": 6.199,
      "text": "ჟოზე ამბობს, ვის უნახავს ტორტი"
    },
    {
      "start": 151.599,
      "duration": 6.881,
      "text": "ექვსკუთხედი და იქნება ექვსი გვერდიც"
    },
    {
      "start": 155.239,
      "duration": 6.681,
      "text": "მეტის, მეტის მეტი. თანაც ყველამ"
    },
    {
      "start": 158.48,
      "duration": 7.52,
      "text": "თითოკუთხე მოვაჭერით, თუ მას კიდევ ვინმე"
    },
    {
      "start": 161.92,
      "duration": 7.72,
      "text": "რომ გვესტუმროს, რა ვაჭამოთ სტუმარს. მერე"
    },
    {
      "start": 166.0,
      "duration": 7.319,
      "text": "ოთხი ეშლება და ექვსი სადარკვიოს. თავგზას"
    },
    {
      "start": 169.64,
      "duration": 6.92,
      "text": "კიდევ უარესად ნუ ავურევთ პიოს. მოკლედ,"
    },
    {
      "start": 173.319,
      "duration": 6.521,
      "text": "ტორტის მცხობელის რომ არ დავიდოთ ბრალი,"
    },
    {
      "start": 176.56,
      "duration": 6.759,
      "text": "თან ყველას რომ ბლომად გვერგოს, ტორტი"
    },
    {
      "start": 179.84,
      "duration": 6.679,
      "text": "იყოს მრგვალი. გადაწყვიტეს"
    },
    {
      "start": 183.319,
      "duration": 6.84,
      "text": "და პიოსაც ისე მიუთითეს, ადვილად რომ"
    },
    {
      "start": 186.519,
      "duration": 6.681,
      "text": "გაიგოს და დაიხსომოს კიდეც. არ გამოვა"
    },
    {
      "start": 190.159,
      "duration": 6.521,
      "text": "ჩვენი ტორტი ოთხკუთხედი იყოს. ვთქვათ"
    },
    {
      "start": 193.2,
      "duration": 6.88,
      "text": "მოჰგავდეს ოთხკუთხიან ამ შენს ტელევიზორს"
    },
    {
      "start": 196.68,
      "duration": 7.4,
      "text": "აღარ უნდა დიდი ფიქრი ან და ფართი ფურთი"
    },
    {
      "start": 200.08,
      "duration": 7.32,
      "text": "ტორტს ზედხედი უნდა ჰქონდეს მრგვალი"
    },
    {
      "start": 204.08,
      "duration": 7.439,
      "text": "როგორც ბურთი ნახე რა ლამაზად და ზუსტად"
    },
    {
      "start": 207.4,
      "duration": 8.039,
      "text": "აგიხსენით ხოდა ზუსტად ასეთივე იმედი"
    },
    {
      "start": 211.519,
      "duration": 8.44,
      "text": "გვაქვს შენი ეს იყო და პიოს სახლში მხოლოდ"
    },
    {
      "start": 215.439,
      "duration": 6.16,
      "text": "პიო დარჩა სხვები სადღაც გაეშურნენ ალბათ"
    },
    {
      "start": 219.959,
      "duration": 4.801,
      "text": "გასაპრანჭად"
    },
    {
      "start": 221.599,
      "duration": 6.84,
      "text": "ტორტ მცხობელს სულ არა აქვს მარტოობის"
    },
    {
      "start": 224.76,
      "duration": 6.36,
      "text": "ჯავრი. უხარია კიდეც ხელს რომ არ შეუშლის"
    },
    {
      "start": 228.439,
      "duration": 6.053,
      "text": "არვინ აქეთ ცომს ზელს და"
    },
    {
      "start": 231.12,
      "duration": 3.959,
      "text": "ელექტროსახობუმელს მართავს. იქით კიდევ"
    },
    {
      "start": 234.492,
      "duration": 4.708,
      "text": "[მუსიკა]"
    },
    {
      "start": 235.079,
      "duration": 8.44,
      "text": "იმ ოთხკუთხა ტელევიზორს ჩართავს, რადგან"
    },
    {
      "start": 239.2,
      "duration": 8.599,
      "text": "მალე დაიწყება მთელ ამ წელიწადში რაგბის"
    },
    {
      "start": 243.519,
      "duration": 8.481,
      "text": "სულ სულ სულ ყველაზე გადამწყვეტი მატჩი."
    },
    {
      "start": 247.799,
      "duration": 6.998,
      "text": "დიახ, პიოს საოცარი მცხობელი კი ჰქვია,"
    },
    {
      "start": 252.0,
      "duration": 3.68,
      "text": "მაგრამ კიდევ დიდი რაგბის დიდი ქომაგია,"
    },
    {
      "start": 254.797,
      "duration": 4.122,
      "text": "[მუსიკა]"
    },
    {
      "start": 255.68,
      "duration": 5.04,
      "text": "მატჩს უყურებს და თან ახსოვს დიდი"
    },
    {
      "start": 258.919,
      "duration": 5.401,
      "text": "საქმიანდეს."
    },
    {
      "start": 260.72,
      "duration": 5.28,
      "text": "ტორტი არა ტელევიზორს ბურთს რომ უნდა"
    },
    {
      "start": 264.32,
      "duration": 6.319,
      "text": "ჰგავდეს [მუსიკა]"
    },
    {
      "start": 266.0,
      "duration": 7.56,
      "text": "და სულ მალე ჩვენი პიო გაიხარებს ორ გზის."
    },
    {
      "start": 270.639,
      "duration": 4.761,
      "text": "გამარჯვებაც, გამოცხვება და ლამაზი"
    },
    {
      "start": 273.56,
      "duration": 5.44,
      "text": "ტორტიც."
    },
    {
      "start": 275.4,
      "duration": 7.32,
      "text": "უკვე ყველა შეკრებილა ჟოზეფინას სახლში და"
    },
    {
      "start": 279.0,
      "duration": 7.36,
      "text": "სუფრასაც უთვალთვალებს გემრიელად გაშლილს."
    },
    {
      "start": 282.72,
      "duration": 7.88,
      "text": "ხოლო სუფრა მხოლოდ იმას ელოდება, როდის"
    },
    {
      "start": 286.36,
      "duration": 7.72,
      "text": "დაამშვენებს უფრო მეტად საზეიმო ტორტი."
    },
    {
      "start": 290.6,
      "duration": 8.439,
      "text": "მალე პიოს ხმაც გაის, როგორც ბაქიბუქი."
    },
    {
      "start": 294.08,
      "duration": 8.399,
      "text": "ტორტი მომაქვს არნახული, ჩააქრეთო შუქი."
    },
    {
      "start": 299.039,
      "duration": 6.681,
      "text": "შუქი ქვრება, ვეღარ ითმენს ხუთი წყვილი"
    },
    {
      "start": 302.479,
      "duration": 8.041,
      "text": "თვალი. ჩქარა, ჩქარა მოიტანეთ ლამაზი და"
    },
    {
      "start": 305.72,
      "duration": 9.319,
      "text": "მრგვალი და რას ხედავს სანთლის შუქზე"
    },
    {
      "start": 310.52,
      "duration": 8.119,
      "text": "პიოს პილო მოდის ხელში მოგრძო ნესვის"
    },
    {
      "start": 315.039,
      "duration": 5.961,
      "text": "ფორმის ოვალური ტორტით ჟოზე ცდილობს ეს"
    },
    {
      "start": 318.639,
      "duration": 5.521,
      "text": "ამბავი სწრაფად გაარკვიოს"
    },
    {
      "start": 321.0,
      "duration": 7.639,
      "text": "ჩვენ ხომ მრგვალზე შევთანხმდითო ეკითხება"
    },
    {
      "start": 324.16,
      "duration": 6.44,
      "text": "პიოს და ეს ნუთუ ოთხკუთხაა ცხარობს"
    },
    {
      "start": 328.639,
      "duration": 4.28,
      "text": "სპილოპიო [მუსიკა]"
    },
    {
      "start": 330.6,
      "duration": 4.0,
      "text": "სად გინახავთ თქვენ ამ ფორმი მის"
    },
    {
      "start": 332.919,
      "duration": 5.961,
      "text": "ტელევიზორიო"
    },
    {
      "start": 334.6,
      "duration": 7.56,
      "text": "იმედია არ მიპირებთ მოდებასო შარის"
    },
    {
      "start": 338.88,
      "duration": 5.36,
      "text": "ბურთის ფორმის მითხარით და ბურთის ფორმის"
    },
    {
      "start": 342.16,
      "duration": 6.28,
      "text": "არის"
    },
    {
      "start": 344.24,
      "duration": 8.16,
      "text": "ეცინება ჟოზეფინას და მოითხოვს სიტყვას"
    },
    {
      "start": 348.44,
      "duration": 5.64,
      "text": "პიოსავით ვერა მაგრამ რაგბი ყველას"
    },
    {
      "start": 352.4,
      "duration": 4.48,
      "text": "გვიყვარს"
    },
    {
      "start": 354.08,
      "duration": 7.559,
      "text": "ხოლო პიოს ვერ დავარქმევთ დაბნეულს და"
    },
    {
      "start": 356.88,
      "duration": 9.439,
      "text": "ორპირს მან ხომ ტორტი გამოგვიცხო რაგბის"
    },
    {
      "start": 361.639,
      "duration": 8.481,
