  "auto": true,
  "snippets": [
    {
      "start": 4.24,
      "duration": 9.8,
      "text": "თებროლე და თანო ერთი ციცქნა, ორი და"
    },
    {
      "start": 9.639,
      "duration": 7.64,
      "text": "ყველამ იცით მემგონი ახლოდან ან შორიდან"
    },
    {
      "start": 14.04,
      "duration": 4.8,
      "text": "ხოლო ჯერ თუ არ იცით გაცნობის დრო"
    },
    {
      "start": 17.279,
      "duration": 7.0,
      "text": "დამდგარა"
    },
    {
      "start": 18.84,
      "duration": 9.72,
      "text": "თებრო ცოტა დიდია თანო ცოტა პატარა ორივეს"
    },
    {
      "start": 24.279,
      "duration": 5.681,
      "text": "აქვს ლამაზი თვალები და კაბები და ყველაზე"
    },
    {
      "start": 28.56,
      "duration": 6.44,
      "text": "მთავარი"
    },
    {
      "start": 29.96,
      "duration": 9.64,
      "text": "მხიარული ამბები. ამბებით ივსება სახლი,"
    },
    {
      "start": 35.0,
      "duration": 6.8,
      "text": "ეზო, უბანი, მითუმეტეს როდესაც დრო აქვთ"
    },
    {
      "start": 39.6,
      "duration": 5.76,
      "text": "თავისუფალი"
    },
    {
      "start": 41.8,
      "duration": 7.2,
      "text": "და რადგანაც ასეთი დრო აქვთ ლამის"
    },
    {
      "start": 45.36,
      "duration": 4.359,
      "text": "ყოველთვის, ხშირად დგება თანოს ამ"
    },
    {
      "start": 49.0,
      "duration": 2.32,
      "text": "შეკითხვის [მუსიკა]"
    },
    {
      "start": 49.719,
      "duration": 3.761,
      "text": "მომენტიც."
    },
    {
      "start": 51.32,
      "duration": 7.239,
      "text": "ახლა რა გავაკეთოთ"
    },
    {
      "start": 53.48,
      "duration": 9.719,
      "text": "და სულ თებრომ [მუსიკა] იცის რაც ჰო იმ"
    },
    {
      "start": 58.559,
      "duration": 8.6,
      "text": "დღესაც პასუხი ისევ თებრომ იკისრა თანო"
    },
    {
      "start": 63.199,
      "duration": 8.361,
      "text": "შენ დაიხუჭე მე კი დავიმალები 10მდე რომ"
    },
    {
      "start": 67.159,
      "duration": 8.681,
      "text": "დაითვლი გაახილე თვალები შეეცადე მიპოვო"
    },
    {
      "start": 71.56,
      "duration": 8.76,
      "text": "თუმცა როგორც დაქალი გეტყვი რომ დამალვაში"
    },
    {
      "start": 75.84,
      "duration": 8.76,
      "text": "ვარ ძალიან მაგარი უთხრა თანოს თებროლემ"
    },
    {
      "start": 80.32,
      "duration": 8.04,
      "text": "კა ალგი უთხრა იმანაც, მაგრამ თვლა რომ"
    },
    {
      "start": 84.6,
      "duration": 8.36,
      "text": "დაიწყო, მერე ცოტა ინანა [მუსიკა]"
    },
    {
      "start": 88.36,
      "duration": 9.84,
      "text": "შემესალა თებროლე უნდა მეთქა ცუდიო"
    },
    {
      "start": 92.96,
      "duration": 8.6,
      "text": "თვალაძელ კალგად ალვიცი ერთი სამი ქუთიო"
    },
    {
      "start": 98.2,
      "duration": 6.12,
      "text": "თანოს მათემატიკა თებროს სულ არ ადარდებს"
    },
    {
      "start": 101.56,
      "duration": 6.64,
      "text": "მაგრამ არ სურს თამაში დაწყებამდე"
    },
    {
      "start": 104.32,
      "duration": 5.399,
      "text": "დამთავრდეს მაშინ შენ დაიმალე მე კი"
    },
    {
      "start": 108.2,
      "duration": 6.426,
      "text": "დავიხუჭები"
    },
    {
      "start": 109.719,
      "duration": 6.72,
      "text": "თქვა ვადა ჩაარაკრაკა ერთი სამი ხუთები."
    },
    {
      "start": 114.626,
      "duration": 6.813,
      "text": "[მუსიკა]"
    },
    {
      "start": 116.439,
      "duration": 9.96,
      "text": "თანომ უნდა იჩქაროს და ნამდვილად ბედია"
    },
    {
      "start": 121.439,
      "duration": 8.361,
      "text": "იქვე ახლოს დივანზე დიდი მწვანე პლედია"
    },
    {
      "start": 126.399,
      "duration": 7.56,
      "text": "მოახერხა დივანთან ფეხაკრეფით მიპარვა"
    },
    {
      "start": 129.8,
      "duration": 9.12,
      "text": "ჩაიმუხლა და პლედი თავზე გადაიფარა"
    },
    {
      "start": 133.959,
      "duration": 10.321,
      "text": "უხარია დამალულს ასე ფიქრობს ნეტაო თებლო"
    },
    {
      "start": 138.92,
      "duration": 10.64,
      "text": "ლოგოლსე ამცინევს მე ყველაფერს ვქედავო"
    },
    {
      "start": 144.28,
      "duration": 9.4,
      "text": "მოიხე ხედა თებრომ და უი მწვანე კუნძულთან"
    },
    {
      "start": 149.56,
      "duration": 9.48,
      "text": "შორია ახლო დივანთან რაღაც ამობურცულა"
    },
    {
      "start": 153.68,
      "duration": 9.6,
      "text": "გაიფიქრა გინდ ნახო პლედი 10 ან 20 ვერ"
    },
    {
      "start": 159.04,
      "duration": 7.36,
      "text": "ექნება ფეხები მითუმეტეს თანოსი"
    },
    {
      "start": 163.28,
      "duration": 7.76,
      "text": "ვეღარც გადაარწმუნებ დარწმუნებულს ამაში"
    },
    {
      "start": 166.4,
      "duration": 8.44,
      "text": "მაგრამ რა კი არ უნდა მალე მორჩეს თამაში"
    },
    {
      "start": 171.04,
      "duration": 9.199,
      "text": "მიდის მოდის ოთახში ვითომ თომ ეძებს"
    },
    {
      "start": 174.84,
      "duration": 9.88,
      "text": "თანოს, თანაც ქება წუწუნით უნდა წაათამოს."
    },
    {
      "start": 180.239,
      "duration": 8.0,
      "text": "ნახე, აქაც არ არის, არც აქ და არც აქ"
    },
    {
      "start": 184.72,
      "duration": 7.48,
      "text": "არის. დამალვაში ყოფილა ჩემზე უფრო"
    },
    {
      "start": 188.239,
      "duration": 7.64,
      "text": "მაგარი. მეტი რა მოვიფიქრო, მეტი როგორ"
    },
    {
      "start": 192.2,
      "duration": 5.679,
      "text": "ვეცადო დამეკარგა თანო ვერ ვპოულობ"
    },
    {
      "start": 195.879,
      "duration": 3.72,
      "text": "ვერსადო. [მუსიკა]"
    },
    {
      "start": 197.879,
      "duration": 5.64,
      "text": "დაეთამაშს"
    },
    {
      "start": 199.599,
      "duration": 5.56,
      "text": "ყოველთვის ეს ხალისი მოჰქონდეს იქით პლედი"
    },
    {
      "start": 203.519,
      "duration": 5.401,
      "text": "ხითხითებს [მუსიკა]"
    },
    {
      "start": 205.159,
      "duration": 3.761,
      "text": "აქეთ თებროქოთქოთებს"
    },
    {
      "start": 209.239,
      "duration": 6.841,
      "text": "დრო გასულა დრო გადის კიდევ ბევრი დრო"
    },
    {
      "start": 213.519,
      "duration": 4.881,
      "text": "გავა ვიდრე მოსწყინდებოდეთ ამათ"
    },
    {
      "start": 216.08,
      "duration": 6.439,
      "text": "დამალობანა"
    },
    {
      "start": 218.4,
      "duration": 5.68,
      "text": "ალბათ ბევრჯერ დათვლიან 10მდე და 10"
    },
    {
      "start": 222.519,
      "duration": 4.92,
      "text": "ამდენს"
    },
    {
      "start": 224.08,
      "duration": 5.359,
      "text": "ანდა იქნებ თამაში არც არასდროს"
    },
    {
      "start": 227.439,
      "duration": 6.401,
      "text": "დამთავრდეს,"
    },
    {
      "start": 229.439,
      "duration": 10.52,
      "text": "მაგრამ პლედის ქვემოდან ახლა სულ სხვა"
    },
    {
      "start": 233.84,
      "duration": 8.84,
      "text": "ხმებია. უი, ამასობაში თანოს ჩასძინებია."
    },
    {
      "start": 239.959,
      "duration": 6.961,
      "text": "ჩაიძინოს თებრომაც."
    },
    {
      "start": 242.68,
      "duration": 6.8,
      "text": "დას რომ არ დავაცილოთ და ორივე საწოლზე"
    },
    {
      "start": 246.92,
      "duration": 6.2,
      "text": "ფრთხილად გადავაწვინოთ."
    },
    {
      "start": 249.48,
      "duration": 7.12,
      "text": "აქეთ დაწევს დის მსგავსი,"
    },
    {
      "start": 253.12,
      "duration": 8.76,
      "text": "იქით დაწევს დის დარი."
    },
    {
      "start": 256.6,
      "duration": 10.84,
      "text": "ესიზმრება ორივეს ერთი ტკბილი სიზმარი."
    },
    {
      "start": 261.88,
      "duration": 11.08,
      "text": "აქ ზღაპარი მორჩა და სად იყო და სად არა,"
    },
    {
      "start": 267.44,
      "duration": 6.479,
      "text": "შენი ძილიც მოფრინდა, მეგობარო პატარა. აი"
    },
    {
      "start": 272.96,
      "duration": 5.12,
      "text": "უკვე [მუსიკა]"
    },
    {
      "start": 273.919,
      "duration": 12.761,
      "text": "მსუბუქ და ლამაზ ბრთაზეც შეგისვა."
    },
    {
      "start": 278.08,
      "duration": 8.6,
      "text": "იავ ნანა ნანინა ტკბილი ძილი ნებისა."
    },
    {
      "start": 295.408,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 305.233,
      "duration": 2.02,
      "text": "[მუსიკა]"
    },
    {
      "start": 348.463,
      "duration": 2.02,
      "text": "[მუსიკა]"
    }
  ]
