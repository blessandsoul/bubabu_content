{
  "id": "KcDpo6JGAec",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 3.56,
      "duration": 7.84,
      "text": "დავიწყდა, თუმცა ბევრს კარგად მახსოვს მე"
    },
    {
      "start": 6.759,
      "duration": 8.601,
      "text": "ისევ. ადრე კაცი ცხოვრობდა პროფესიით"
    },
    {
      "start": 11.4,
      "duration": 8.84,
      "text": "მეისრე. ბევრგვარია ისარიც და იმისი"
    },
    {
      "start": 15.36,
      "duration": 6.759,
      "text": "მისიაც. ჰოდა ჩვენი მეისრი ამზადებდა"
    },
    {
      "start": 20.24,
      "duration": 4.0,
      "text": "ამისრებს,"
    },
    {
      "start": 22.119,
      "duration": 6.16,
      "text": "თან ისეთებს,"
    },
    {
      "start": 24.24,
      "duration": 9.479,
      "text": "ერთიც რომ არ სცდებოდა სამიზნეს."
    },
    {
      "start": 28.279,
      "duration": 10.921,
      "text": "მეისრე ამ ისრებით მთელ ჯარს ამარაგებდა."
    },
    {
      "start": 33.719,
      "duration": 10.041,
      "text": "ჯარიც ისე ისროდა, ომს არასდროს აგებდა."
    },
    {
      "start": 39.2,
      "duration": 8.16,
      "text": "ამას გარდა მეისრე სამი სავსე მთვარის დარ"
    },
    {
      "start": 43.76,
      "duration": 6.52,
      "text": "ვაჟკაცსაც უზრდიდა სამშობლოს"
    },
    {
      "start": 47.36,
      "duration": 6.44,
      "text": "და თავის თავს."
    },
    {
      "start": 50.28,
      "duration": 5.56,
      "text": "ცოტა იყო ასაკით განსხვავება შვილებში,"
    },
    {
      "start": 53.8,
      "duration": 5.04,
      "text": "როგორც ყველა ზღაპარში და ზოგ"
    },
    {
      "start": 55.84,
      "duration": 7.359,
      "text": "სინამდვილეში. ამ სამიდან პირველი ვაჟი"
    },
    {
      "start": 58.84,
      "duration": 6.599,
      "text": "იყო უფროსი, შუათანა მეორე, მესამე კი"
    },
    {
      "start": 63.199,
      "duration": 5.401,
      "text": "უმცროსი."
    },
    {
      "start": 65.439,
      "duration": 7.081,
      "text": "ზოგი თუკი მშობლისგან ერთ სიტყვას არ"
    },
    {
      "start": 68.6,
      "duration": 6.76,
      "text": "შეისმენს, ეს ბიჭები სულ მხარში ედგნენ"
    },
    {
      "start": 72.52,
      "duration": 6.88,
      "text": "მამა მეისრეს."
    },
    {
      "start": 75.36,
      "duration": 7.56,
      "text": "ერთხელ სინჯეს და მერე დაიდგინეს წესადაც."
    },
    {
      "start": 79.4,
      "duration": 6.6,
      "text": "ყველა ტიპის ისარი თვითონ გამოეცადათ."
    },
    {
      "start": 82.92,
      "duration": 5.505,
      "text": "უნდილ გოგრას ნახავდნენ, თავგანწირვით"
    },
    {
      "start": 86.0,
      "duration": 3.52,
      "text": "ებრძოდნენ, ისრებს, გამოსაცდელებს"
    },
    {
      "start": 88.425,
      "duration": 3.575,
      "text": "[მუსიკა]"
    },
    {
      "start": 89.52,
      "duration": 6.44,
      "text": "უმოწყალოდ ესროდნენ."
    },
    {
      "start": 92.0,
      "duration": 5.28,
      "text": "თანაც ეჯიბრებოდნენ ჩალაგებულს ყორესთან"
    },
    {
      "start": 95.96,
      "duration": 4.799,
      "text": "გოგრას, [მუსიკა]"
    },
    {
      "start": 97.28,
      "duration": 6.44,
      "text": "სხვაზე უფრო მეტს თუ ვინ გააგორებდა."
    },
    {
      "start": 100.759,
      "duration": 4.521,
      "text": "არაერთხელ მომხდარა, რომ მათგანი ყოველი"
    },
    {
      "start": 103.72,
      "duration": 6.8,
      "text": "ამტკიცებდა,"
    },
    {
      "start": 105.28,
      "duration": 8.92,
      "text": "მე ვარო თქვენზე კარგი მსროლელი."
    },
    {
      "start": 110.52,
      "duration": 9.16,
      "text": "ხოლო როცა საკითხი დავით ვერ დაძლეულა,"
    },
    {
      "start": 114.2,
      "duration": 8.16,
      "text": "დავას სახე უცვლია, ჩხუბად გადაქცეულა."
    },
    {
      "start": 119.68,
      "duration": 5.6,
      "text": "ამბის მომსწრე ძველები ძმებზე დღესაც"
    },
    {
      "start": 122.36,
      "duration": 5.6,
      "text": "ყვებიან, ბევრჯერ [მუსიკა] ერთმანეთი რომ"
    },
    {
      "start": 125.28,
      "duration": 5.199,
      "text": "მაგრად მიუტყებიათ."
    },
    {
      "start": 127.96,
      "duration": 6.359,
      "text": "მამას შვილთა [მუსიკა] სიმარჯვით ბევრჯერ"
    },
    {
      "start": 130.479,
      "duration": 7.881,
      "text": "გაუხარია, მაგრამ მათი ჩხუბები არ"
    },
    {
      "start": 134.319,
      "duration": 8.521,
      "text": "მოსწონდა ძალიან და ამ არ მოწონებამ"
    },
    {
      "start": 138.36,
      "duration": 8.36,
      "text": "წააქეზა, უბიძგა, შემსწრეს ძმების მორიგი"
    },
    {
      "start": 142.84,
      "duration": 7.24,
      "text": "შეჯიბრის და ჩხუბისა საკმარისზე მეტად რომ"
    },
    {
      "start": 146.72,
      "duration": 6.32,
      "text": "იყო უკვე გამწყრალი, ჩაედინა რაიმე"
    },
    {
      "start": 150.08,
      "duration": 6.08,
      "text": "მათთვის [მუსიკა] ჭკუის სასწავლი."
    },
    {
      "start": 153.04,
      "duration": 4.559,
      "text": "აქ მოდითო ჭაბუკებს ხელით [მუსიკა] მისცა"
    },
    {
      "start": 156.16,
      "duration": 5.12,
      "text": "ნიშანი."
    },
    {
      "start": 157.599,
      "duration": 6.321,
      "text": "მერე მოატანინა რამდენიმე ისარი ძველი"
    },
    {
      "start": 161.28,
      "duration": 4.599,
      "text": "დაწუნებული გამოუსადეგარი"
    },
    {
      "start": 163.92,
      "duration": 5.52,
      "text": "უფროს უთხრა [მუსიკა]"
    },
    {
      "start": 165.879,
      "duration": 7.561,
      "text": "ისრები ერთ მსხვილ კონად შეკარი"
    },
    {
      "start": 169.44,
      "duration": 8.04,
      "text": "რა ხდებაო ბიჭებმა წაიკრძელეს კისრები"
    },
    {
      "start": 173.44,
      "duration": 9.079,
      "text": "უფროსმა კი ბეჯითად იწყო შეკვრა ისრების"
    },
    {
      "start": 177.48,
      "duration": 7.92,
      "text": "კარგი უთხრა მეისრემ გონი უნდა ეყოსო ახლა"
    },
    {
      "start": 182.519,
      "duration": 5.921,
      "text": "უმცროს მიეცი [მუსიკა] კონა გადატეხოსო"
    },
    {
      "start": 185.4,
      "duration": 4.919,
      "text": "მისწვდა ისრებს სუმცროსი მტკიცედ"
    },
    {
      "start": 188.44,
      "duration": 5.2,
      "text": "განალაჩრულად"
    },
    {
      "start": 190.319,
      "duration": 6.161,
      "text": "კონას ჯერ დაეჭიდა მერე დაეჯაჯგურა"
    },
    {
      "start": 193.64,
      "duration": 6.64,
      "text": "წითულდებოდა ბრდღვინავდა რაღაც აღარ"
    },
    {
      "start": 196.48,
      "duration": 6.52,
      "text": "შვრებოდა კონა არ იმტვრეოდა"
    },
    {
      "start": 200.28,
      "duration": 7.48,
      "text": "ისევ კონად რჩებოდა [მუსიკა]"
    },
    {
      "start": 203.0,
      "duration": 6.68,
      "text": "მამამ უთხრა გეყოფა გააგრძელე სხვა დროსო"
    },
    {
      "start": 207.76,
      "duration": 3.52,
      "text": "შუათანას მიეცი [მუსიკა] ახლა მაგანს"
    },
    {
      "start": 209.68,
      "duration": 5.36,
      "text": "სცადოსო"
    },
    {
      "start": 211.28,
      "duration": 6.56,
      "text": "შუათანა მისრები თავის მსხვერპლად იგულა"
    },
    {
      "start": 215.04,
      "duration": 7.04,
      "text": "პატარა ძმას შეხი ხიმა დამცინავად დიდ"
    },
    {
      "start": 217.84,
      "duration": 8.479,
      "text": "გულად, თუმცა მალე ღიმილი უგზოუკლოდ"
    },
    {
      "start": 222.08,
      "duration": 6.84,
      "text": "გააქრო, რადგან ისრებს, ვერც იმან"
    },
    {
      "start": 226.319,
      "duration": 6.321,
      "text": "ვერაფერი დააკლო."
    },
    {
      "start": 228.92,
      "duration": 6.36,
      "text": "მამამ უთხრა, მაგ საქმეს იქნებ სხვა დროს"
    },
    {
      "start": 232.64,
      "duration": 7.08,
      "text": "ეწიო. ახლა კი ეგისრები [მუსიკა]"
    },
    {
      "start": 235.28,
      "duration": 7.28,
      "text": "უფროს გადაეციო. ჩამოართვა უფროსმა მართლა"
    },
    {
      "start": 239.72,
      "duration": 5.159,
      "text": "დიდი კაცივით, თან სახეში შეხურებ"
    },
    {
      "start": 242.56,
      "duration": 4.12,
      "text": "შუათანას დაცინვით."
    },
    {
      "start": 244.879,
      "duration": 4.761,
      "text": "და მცინავი ღიმილით თავი [მუსიკა] თუ"
    },
    {
      "start": 246.68,
      "duration": 6.479,
      "text": "დაინავსა, რადგან გამოუვიდა არაფერი"
    },
    {
      "start": 249.64,
      "duration": 8.4,
      "text": "იმასაც. [მუსიკა] მაინც იქადნებოდა, მამამ"
    },
    {
      "start": 253.159,
      "duration": 6.681,
      "text": "აღარ აცალა, გახსნა კონა ისრების, თითო"
    },
    {
      "start": 258.04,
      "duration": 4.039,
      "text": "ისრად დაშალა, [მუსიკა]"
    },
    {
      "start": 259.84,
      "duration": 5.4,
      "text": "დაურიგა ჭაბუკებს,"
    },
    {
      "start": 262.079,
      "duration": 5.361,
      "text": "ეს პატივიც დამდეთო. აბა ახლა ამათი"
    },
    {
      "start": 265.24,
      "duration": 4.76,
      "text": "გადატეხა სცადეთო."
    },
    {
      "start": 267.44,
      "duration": 7.24,
      "text": "აბა რად მოგატყუოთ? უნდა გითხრათ"
    },
    {
      "start": 270.0,
      "duration": 9.479,
      "text": "ნამდვილად. ძმებმა თითო ისარი გადატეხეს"
    },
    {
      "start": 274.68,
      "duration": 8.92,
      "text": "ადვილად. მამამ გულში გაივლო, ყოჩაღ ჩემო"
    },
    {
      "start": 279.479,
      "duration": 6.16,
      "text": "ილეთო. მერე შვილებს მიმართა, ახლა"
    },
    {
      "start": 283.6,
      "duration": 5.599,
      "text": "მომისმინეთო."
    },
    {
      "start": 285.639,
      "duration": 5.321,
      "text": "კარგად იცით, ჯარი გვყავს მართლა"
    },
    {
      "start": 289.199,
      "duration": 6.641,
      "text": "ძლევასილი."
    },
    {
      "start": 290.96,
      "duration": 8.0,
      "text": "ბევრს გონია ისრები ჩვენი ჯარის კოზირი,"
    },
    {
      "start": 295.84,
      "duration": 7.28,
      "text": "მაგრამ სინამდვილეში მტერი გარბის"
    },
    {
      "start": 298.96,
      "duration": 8.48,
      "text": "ბეტკრული, რადგან ჩვენი არმია მუშტად არის"
    },
    {
      "start": 303.12,
      "duration": 8.56,
      "text": "შეკრული. ახლა კიდევ სამივეორი მძლავრი"
    },
    {
      "start": 307.44,
      "duration": 6.52,
      "text": "ხელითო ისრის შეკვრაებით"
    },
    {
      "start": 311.68,
      "duration": 5.16,
      "text": "ვერადაკელითო, [მუსიკა]"
    },
    {
      "start": 313.96,
      "duration": 5.04,
      "text": "მაგრამ სამაგიეროდ"
    },
    {
      "start": 316.84,
      "duration": 6.078,
      "text": "რა მაქვს დასაფიცარი"
    },
    {
      "start": 319.0,
      "duration": 5.16,
      "text": "წკირებივით დატეხეთ თვითომ თითოისარი"
    },
    {
      "start": 322.918,
      "duration": 3.922,
      "text": "[მუსიკა]"
    },
    {
      "start": 324.16,
      "duration": 6.24,
      "text": "ერთმანეთის დაკარგვა თქვენც ასევე"
    },
    {
      "start": 326.84,
      "duration": 5.84,
      "text": "გაწყენთო ერთად თუ [მუსიკა] არ იქნებით"
    },
    {
      "start": 330.4,
      "duration": 6.273,
      "text": "ყველა დაგამარცხებთო"
    },
    {
      "start": 332.68,
      "duration": 5.799,
      "text": "ხოლო თუკი ერთობა გაიხადეთ ჩვევადო ისე"
    },
    {
      "start": 336.673,
      "duration": 4.047,
      "text": "[მუსიკა] გაძლიერდებით"
    },
    {
      "start": 338.479,
      "duration": 6.84,
      "text": "ვევინ მოგერევათო"
    },
    {
      "start": 340.72,
      "duration": 6.12,
      "text": "იმიტომ რომ ყველასთვის დიდია თუ ბავშვია"
    },
    {
      "start": 345.319,
      "duration": 3.241,
      "text": "ერთობაში"
    },
    {
      "start": 346.84,
      "duration": 3.479,
      "text": "ძალაა"
    },
    {
      "start": 348.56,
      "duration": 4.759,
      "text": "ძალა"
    },
    {
      "start": 350.319,
      "duration": 3.0,
      "text": "ერთობაშია"
    },
    {
      "start": 354.479,
      "duration": 5.72,
      "text": "ზღაპარი მორჩა"
    },
    {
      "start": 356.68,
      "duration": 7.92,
      "text": "და სად იყო [მუსიკა] და სად არა შენი"
    },
    {
      "start": 360.199,
      "duration": 4.401,
      "text": "ძილიც მოფრინდა მეგობარო პატარა"
    },
    {
      "start": 364.84,
      "duration": 7.6,
      "text": "აი უკვე მსუბუქ და ლამაზ ფრთაზეც შეგისვა"
    },
    {
