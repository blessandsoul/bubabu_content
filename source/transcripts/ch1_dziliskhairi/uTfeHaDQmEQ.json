{
  "id": "uTfeHaDQmEQ",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 5.68,
      "duration": 9.52,
      "text": "ერთ საღამოს, როცა იყო სკვერში ჯდომის"
    },
    {
      "start": 9.559,
      "duration": 9.521,
      "text": "ამინდი, სკვერში ისხდნენ ჟოზე, პიო,"
    },
    {
      "start": 15.2,
      "duration": 10.159,
      "text": "დუდუნა და მამინი. პიო იმათ აჩვენებდა და"
    },
    {
      "start": 19.08,
      "duration": 9.76,
      "text": "აქებდა აბა რას? რას და თავის ახალთახალ"
    },
    {
      "start": 25.359,
      "duration": 3.481,
      "text": "მაგარ ფოტოაპარატს."
    },
    {
      "start": 29.08,
      "duration": 6.88,
      "text": "მეგობრები ულოცავდნენ, უწონებდნენ,"
    },
    {
      "start": 32.32,
      "duration": 7.0,
      "text": "უქებდნენ, თან ერთმანეთს რა თქმა უნდა"
    },
    {
      "start": 35.96,
      "duration": 6.24,
      "text": "ფოტოებსაც უღებდნენ და როდესაც ყველა"
    },
    {
      "start": 39.32,
      "duration": 9.16,
      "text": "ფონზე გადაიღეს კინაღამ,"
    },
    {
      "start": 42.2,
      "duration": 11.08,
      "text": "ჟოზემ სივრცეს გახედა და აი ეს დაინახა."
    },
    {
      "start": 48.48,
      "duration": 9.64,
      "text": "მთას თავს ადგა სავსე მთვარე, განა ერთი"
    },
    {
      "start": 53.28,
      "duration": 7.56,
      "text": "ნამცეცი. მთვარე იყო უდიდესი, თანაც"
    },
    {
      "start": 58.12,
      "duration": 5.96,
      "text": "ულამაზესი"
    },
    {
      "start": 60.84,
      "duration": 6.639,
      "text": "და იკითხა მაშინ ჟოზემ, აქ როდემდე"
    },
    {
      "start": 64.08,
      "duration": 4.96,
      "text": "ვიყოთო, წავიდეთ და ფოტო მთვარის ფონზე"
    },
    {
      "start": 67.479,
      "duration": 5.64,
      "text": "გადავიღოთო"
    },
    {
      "start": 69.04,
      "duration": 8.2,
      "text": "და ოთხივე მეგობარი იმ მთისაკენ გაიქცა."
    },
    {
      "start": 73.119,
      "duration": 9.401,
      "text": "პიო უკან ჩამორჩა და ერთხელ კიდეც წაიქცა."
    },
    {
      "start": 77.24,
      "duration": 8.12,
      "text": "მის ძახოდა შეანელეთ ეგ ჩლიქი და თათიო."
    },
    {
      "start": 82.52,
      "duration": 5.84,
      "text": "ნეტავ ხომ არ დაგავიწყდათ? მე მაქვს"
    },
    {
      "start": 85.36,
      "duration": 3.0,
      "text": "აპარატიო."
    },
    {
      "start": 88.425,
      "duration": 6.654,
      "text": "[მუსიკა] არცერთი არ დაელოდა წინ წასული"
    },
    {
      "start": 91.0,
      "duration": 6.079,
      "text": "სამიდან და ბუნჩულა პიოს პილომ მთაზეც"
    },
    {
      "start": 95.079,
      "duration": 7.641,
      "text": "ბოლო ავიდა."
    },
    {
      "start": 97.079,
      "duration": 9.921,
      "text": "ავიდა და აი იმას, რაც ასულმა იხილა. იმ"
    },
    {
      "start": 102.72,
      "duration": 8.8,
      "text": "სამივით მიაშტერდა, იმ სამივით პირღია."
    },
    {
      "start": 107.0,
      "duration": 9.36,
      "text": "არცერთს აღარაფერი და აღარავინ ახსოვდა."
    },
    {
      "start": 111.52,
      "duration": 9.519,
      "text": "მთვარე უფრო საოცარი გამხდარიყო ახლოდან."
    },
    {
      "start": 116.36,
      "duration": 12.08,
      "text": "მის მშვენებას რა აღწერდა, რა ზღაპარი, რა"
    },
    {
      "start": 121.039,
      "duration": 10.801,
      "text": "ლექსი იყო უფრო უდიდესი, უფრო ულამაზესი."
    },
    {
      "start": 128.44,
      "duration": 6.079,
      "text": "ბოლოს ჟოზე გამოერკვა, გვიანი საღამოა,"
    },
    {
      "start": 131.84,
      "duration": 5.96,
      "text": "სავსე მთვარე მალე ჩავა და სავსე მზე"
    },
    {
      "start": 134.519,
      "duration": 6.08,
      "text": "ამოვა. დროა პიოს აპარატს, რომ თავსახური"
    },
    {
      "start": 137.8,
      "duration": 6.92,
      "text": "მოვაძროთ, გადაღება დავიწყოთ და ბევრი"
    },
    {
      "start": 140.599,
      "duration": 8.201,
      "text": "ფოტო მოვასწროთ. გადაიღეს ფოტოები იქიდან"
    },
    {
      "start": 144.72,
      "duration": 7.68,
      "text": "და აქედან, ზოგი დადგა ყირაზე და ზოგმა"
    },
    {
      "start": 148.8,
      "duration": 7.12,
      "text": "სალტო აკეთა, მაგრამ ყველა ამ ფოტოდან,"
    },
    {
      "start": 152.4,
      "duration": 7.199,
      "text": "როგორც მერე გამოჩნდა, მეგობრებთან ერთად"
    },
    {
      "start": 155.92,
      "duration": 7.52,
      "text": "მთვარე არცერთზე არ აღმოჩნდა."
    },
    {
      "start": 159.599,
      "duration": 6.521,
      "text": "უცებ ჟოზემ მოისაზრა, ფოტოს გადაღებისას"
    },
    {
      "start": 163.44,
      "duration": 5.0,
      "text": "მთვარის ფონზე რომ გამოჩნდეთ, გრძელ"
    },
    {
      "start": 166.12,
      "duration": 5.08,
      "text": "კისერზე შეგისვამთ."
    },
    {
      "start": 168.44,
      "duration": 6.24,
      "text": "თქვა და ასეც გააკეთა. მეგობრებს არ"
    },
    {
      "start": 171.2,
      "duration": 6.8,
      "text": "უმტყუნა, ხან მამინი შემოისვა კისერზე,"
    },
    {
      "start": 174.68,
      "duration": 7.08,
      "text": "ხან დუდუნა. პიომ დიდხანს აჩხაკუნა"
    },
    {
      "start": 178.0,
      "duration": 7.519,
      "text": "აპარატი თავისი, გადაიღო 100 ფოტო ან"
    },
    {
      "start": 181.76,
      "duration": 7.72,
      "text": "1000, რა ვიცი. მათაც თვალეს ფოტოები"
    },
    {
      "start": 185.519,
      "duration": 7.121,
      "text": "ძლივსღა დაითვალეს და პიომაც თქვა: \"ეთი"
    },
    {
      "start": 189.48,
      "duration": 7.36,
      "text": "ფოტო მეც კი მინდა მთვარესთან. რა თქმა"
    },
    {
      "start": 192.64,
      "duration": 6.482,
      "text": "უნდა, უთხრა ჟოზემ, შენც ახლავე გიშველი\""
    },
    {
      "start": 196.84,
      "duration": 3.16,
      "text": "დაიხარა და მეგობარს გაუწოდა კისერი."
    },
    {
      "start": 199.122,
      "duration": 3.798,
      "text": "[მუსიკა]"
    },
    {
      "start": 200.0,
      "duration": 6.959,
      "text": "პიო ცდილობს აბობღებას, ჟოზე მაგრად"
    },
    {
      "start": 202.92,
      "duration": 8.48,
      "text": "ირწევა და ხან ერთი ვარდება და ხან მეორე"
    },
    {
      "start": 206.959,
      "duration": 8.321,
      "text": "იქცევა. პიომ მიხვდა, ვერ შეძლებდა დიდ"
    },
    {
      "start": 211.4,
      "duration": 6.36,
      "text": "მთვარემდე ასვლას და რაღა ექნა მოწყენილი"
    },
    {
      "start": 215.28,
      "duration": 6.319,
      "text": "მთიდან წამოლასლასდა."
    },
    {
      "start": 217.76,
      "duration": 7.399,
      "text": "მოიწყინეს სხვებმაც ჟოზემ, მამინიმ და"
    },
    {
      "start": 221.599,
      "duration": 5.36,
      "text": "დუდუნამ. დუდუს ცრემლი მოერია და"
    },
    {
      "start": 225.159,
      "duration": 5.28,
      "text": "ამოისლუკუნა."
    },
    {
      "start": 226.959,
      "duration": 7.28,
      "text": "სულ ახლახანს რა სიცილი, რა კისკისი"
    },
    {
      "start": 230.439,
      "duration": 5.561,
      "text": "გვქონდაო. ახლა რაღა გვეშველება პიო"
    },
    {
      "start": 234.239,
      "duration": 5.84,
      "text": "დაგვიღონდაო."
    },
    {
      "start": 236.0,
      "duration": 7.68,
      "text": "ეს შენს გამოემართა, ჩვენო კარგო მთვარეო."
    },
    {
      "start": 240.079,
      "duration": 7.36,
      "text": "რა ვქნათ? იქნებ შენვე გვითხრა, ცოტა"
    },
    {
      "start": 243.68,
      "duration": 8.279,
      "text": "დაგვეხმარეო. მერე სლუკუნს მოუმატა კიდევ"
    },
    {
      "start": 247.439,
      "duration": 8.561,
      "text": "უფრო და უფრო მთვარემ დუდუს უსმინა და"
    },
    {
      "start": 251.959,
      "duration": 8.12,
      "text": "გულმა ვეღარ გაუძლო. პიო ამ დროს მთის"
    },
    {
      "start": 256.0,
      "duration": 6.16,
      "text": "წვერს უკვე ჩასცდენოდა კინაღამ. დაუძახეს,"
    },
    {
      "start": 260.079,
      "duration": 5.201,
      "text": "მიიხედა"
    },
    {
      "start": 262.16,
      "duration": 7.08,
      "text": "ეს რა დაინახა."
    },
    {
      "start": 265.28,
      "duration": 8.84,
      "text": "დიდებული მთვარე თურმე თვითონ ჩამოსულა"
    },
    {
      "start": 269.24,
      "duration": 8.519,
      "text": "ძირს. რატომ? პიოს პილოსთან რომ გადაიღოს"
    },
    {
      "start": 274.12,
      "duration": 8.4,
      "text": "სურათი. და თავიდან პიოს პილოტს"
    },
    {
      "start": 277.759,
      "duration": 7.521,
      "text": "გამართავდა აბა რას? რა თქმა უნდა, თავის"
    },
    {
      "start": 282.52,
      "duration": 5.76,
      "text": "ახალ მაგარ ფოტოაპარატს."
    },
    {
      "start": 285.28,
      "duration": 5.6,
      "text": "მეგობრებმა კიდევ უფრო მაგრად გაიხარეს და"
    },
    {
      "start": 288.28,
      "duration": 6.16,
      "text": "ბევრი ფოტო გადაიღეს იმ დიდებულ"
    },
    {
      "start": 290.88,
      "duration": 7.48,
      "text": "მთვარესთან. ფოტოებზე მათ სახეებს სავსე"
    },
    {
      "start": 294.44,
      "duration": 6.44,
      "text": "მთვარე აშუქებს. ზოგი სახლში წამოიღეს,"
    },
    {
      "start": 298.36,
      "duration": 6.16,
      "text": "ზოგი მთვარეს აჩუქეს."
    },
    {
      "start": 300.88,
      "duration": 7.08,
      "text": "ბოლოს ისევ მთვარემ უთხრა: \"პატივი ხომ"
    },
    {
      "start": 304.52,
      "duration": 5.92,
      "text": "გეცითო, ჩემი წასვლის დრო მოვიდა და"
    },
    {
      "start": 307.96,
      "duration": 6.44,
      "text": "თქვენც გაიქეცითო.\""
    },
    {
      "start": 310.44,
      "duration": 6.199,
      "text": "მეგობრებსაც დავრჩებითო აღარ დაუჟინიათ,"
    },
    {
      "start": 314.4,
      "duration": 5.84,
      "text": "სახლში დაბრუნებულან"
    },
    {
      "start": 316.639,
      "duration": 9.241,
      "text": "და ტკბილად დაუძინიათ."
    },
    {
      "start": 320.24,
      "duration": 8.36,
      "text": "ასე მორჩა ზღაპარი და სად იყო და სად არა,"
    },
    {
      "start": 325.88,
      "duration": 4.28,
      "text": "შენი ძილიც მოფრენილა, მეგობარო [მუსიკა]"
    },
    {
      "start": 328.6,
      "duration": 4.143,
      "text": "პატარა."
    },
    {
      "start": 330.16,
      "duration": 2.64,
      "text": "აი უკვე სიზმარივით"
    },
    {
      "start": 332.743,
      "duration": 2.977,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 332.8,
      "duration": 6.8,
      "text": ">> ლამაზ ფთაზეც შეგისვა."
    },
    {
      "start": 335.72,
      "duration": 8.68,
      "text": "იავ ნანა ვარდოვ ნანა."
    },
    {
      "start": 339.6,
      "duration": 4.8,
      "text": "ტკბილი ძილი ნებისა"
    },
    {
      "start": 363.529,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 372.12,
      "duration": 2.079,
      "text": ">> เ"
    },
    {
      "start": 378.594,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 401.919,
      "duration": 2.081,
      "text": ">> เ"
    },
    {
      "start": 413.964,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    }
  ]
}