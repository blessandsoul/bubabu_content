{
  "id": "m8T4Rw7URG8",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 2.8,
      "duration": 5.64,
      "text": "ტყის ნაპირას,"
    },
    {
      "start": 4.88,
      "duration": 8.759,
      "text": "იქ სადაც მდელო იყო მზიანი,"
    },
    {
      "start": 8.44,
      "duration": 9.4,
      "text": "ერთი კატა ცხოვრობდა, ნაკითხი და ჭკვიანი,"
    },
    {
      "start": 13.639,
      "duration": 6.88,
      "text": "ღირსეულად დამჭერი თავისა და კუდისა,"
    },
    {
      "start": 17.84,
      "duration": 5.48,
      "text": "გამზრდელი და აღმზრდელი"
    },
    {
      "start": 20.519,
      "duration": 7.041,
      "text": "არაერთი კნუტისა."
    },
    {
      "start": 23.32,
      "duration": 8.959,
      "text": "თუ ეცალა ზამთარში ნებივრობდა ბუხართან,"
    },
    {
      "start": 27.56,
      "duration": 11.6,
      "text": "ზაფხულში კი ტყისპირას სეირნობა უყვარდა"
    },
    {
      "start": 32.279,
      "duration": 8.44,
      "text": "ჰოდა ერთხელ ასე რომ სეირნობდა ნეტარად,"
    },
    {
      "start": 39.16,
      "duration": 6.0,
      "text": "უცბად"
    },
    {
      "start": 40.719,
      "duration": 6.16,
      "text": "ლომის პატარა ბოკვერს გადაეყარა,"
    },
    {
      "start": 45.16,
      "duration": 5.039,
      "text": "უთხრა"
    },
    {
      "start": 46.879,
      "duration": 8.081,
      "text": "ვინმე ბოროტმა რამე არ დაგიშავოს"
    },
    {
      "start": 50.199,
      "duration": 7.121,
      "text": "გარეთ მარტო პატრონმა როგორ გამოგიშვაო?"
    },
    {
      "start": 54.96,
      "duration": 7.079,
      "text": "ასლუკუნდა ბოკვერი."
    },
    {
      "start": 57.32,
      "duration": 7.839,
      "text": "რა ვქნა? არავინ მყავსო თორემ განა მარტო"
    },
    {
      "start": 62.039,
      "duration": 7.841,
      "text": "კაბოდიალი მიყვარსო."
    },
    {
      "start": 65.159,
      "duration": 7.28,
      "text": "კატას გული ეტკინა კეთილი და მზიანი,"
    },
    {
      "start": 69.88,
      "duration": 4.845,
      "text": "მაგრამ როგორც გითხარით კატა იყო"
    },
    {
      "start": 72.439,
      "duration": 2.286,
      "text": "ჭკვიანიც. [მუსიკა]"
    },
    {
      "start": 75.28,
      "duration": 5.4,
      "text": "ამიტომაც თავისთვის გაიფიქრა,"
    },
    {
      "start": 79.08,
      "duration": 6.039,
      "text": "თუმცაო"
    },
    {
      "start": 80.68,
      "duration": 7.745,
      "text": "ახლა არის პატარა, მტირალა და უმწეო."
    },
    {
      "start": 85.119,
      "duration": 4.64,
      "text": "თუკი შეძლო როგორმე დიდობამდე მიღწევა,"
    },
    {
      "start": 88.425,
      "duration": 3.135,
      "text": "[მუსიკა]"
    },
    {
      "start": 89.759,
      "duration": 6.241,
      "text": "უშველებელ"
    },
    {
      "start": 91.56,
      "duration": 4.44,
      "text": "ღრიალა ლომად გადაიქცევა."
    },
    {
      "start": 96.119,
      "duration": 7.04,
      "text": "ბოლოს მაინც კატვრმა სიბრალულმა იძალა."
    },
    {
      "start": 100.399,
      "duration": 5.68,
      "text": "ბოკვერს თათი ჩაკიდა,"
    },
    {
      "start": 103.159,
      "duration": 6.761,
      "text": "სახლში წამოიყვანა,"
    },
    {
      "start": 106.079,
      "duration": 9.0,
      "text": "ალბათ მოაშიაო აქეთი იქით წანწალმა"
    },
    {
      "start": 109.92,
      "duration": 7.559,
      "text": "ნელთბილი რძე ასვა და ჭყინტი ყველი აჭამა"
    },
    {
      "start": 115.079,
      "duration": 5.481,
      "text": "და იმ ღამით, [სუნთქვის შეკვრა] რადგანაც"
    },
    {
      "start": 117.479,
      "duration": 7.627,
      "text": "მფარველს გვერდით [მუსიკა] ეწვინა, ლომის"
    },
    {
      "start": 120.56,
      "duration": 5.12,
      "text": "ბოკვერს მშვიდად და გემრიელად ეძინა."
    },
    {
      "start": 125.106,
      "duration": 4.414,
      "text": "[მუსიკა]"
    },
    {
      "start": 125.68,
      "duration": 9.199,
      "text": "დილიდან კი ჯერ ფეხზე წამომდგარიც არ იყო."
    },
    {
      "start": 129.52,
      "duration": 9.079,
      "text": "კატამ გაზრდა და აღზრდა ერთად დაიწყო."
    },
    {
      "start": 134.879,
      "duration": 7.321,
      "text": "მადლიერი ბოკვერი მიხვდა, ბედის წყალობდა,"
    },
    {
      "start": 138.599,
      "duration": 5.561,
      "text": "თავის გამზრდელს უსმენდა, უჯერებდა,"
    },
    {
      "start": 142.2,
      "duration": 5.399,
      "text": "სწავლობდა"
    },
    {
      "start": 144.16,
      "duration": 5.159,
      "text": "და ისწავლა რაც იქნებ კარგად ჯერ ჩვენც არ"
    },
    {
      "start": 147.599,
      "duration": 5.081,
      "text": "ვიცით."
    },
    {
      "start": 149.319,
      "duration": 6.361,
      "text": "ყოველ დილით კბილების გამოხეხვა ჯაგრისით,"
    },
    {
      "start": 152.68,
      "duration": 5.279,
      "text": "სუფრის სწორად გაწყობის წესი რო ამგვარი,"
    },
    {
      "start": 155.68,
      "duration": 5.52,
      "text": "თეფშის მარჯვნივ დანადევს, თეფშის"
    },
    {
      "start": 157.959,
      "duration": 5.961,
      "text": "მარცხნივ ჩანგალი წყაროდან რომ არ უნდა"
    },
    {
      "start": 161.2,
      "duration": 3.861,
      "text": "წამოიღო ჭიქა და როგორ უნდა თამაში"
    },
    {
      "start": 163.92,
      "duration": 1.239,
      "text": "კნუთთან,"
    },
    {
      "start": 165.061,
      "duration": 4.178,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 165.159,
      "duration": 8.0,
      "text": ">> ლეკვთან, თიკანთან, რომ ტკბილია შაქარი,"
    },
    {
      "start": 169.239,
      "duration": 6.481,
      "text": "რომ ცხარია პილპილი, კურდღელივით ხტუნვა"
    },
    {
      "start": 173.159,
      "duration": 6.641,
      "text": "და მწევარივით სირბილი."
    },
    {
      "start": 175.72,
      "duration": 9.48,
      "text": "ამას გარდა ბოკვერი იზრდებოდა ტანითაც,"
    },
    {
      "start": 179.8,
      "duration": 9.4,
      "text": "კატას დაეწია და უფრო შორსაც წავიდა. აბა"
    },
    {
      "start": 185.2,
      "duration": 10.52,
      "text": "ზუსტად ლომების გასაზომად ვის ცხელა,"
    },
    {
      "start": 189.2,
      "duration": 11.92,
      "text": "თორემ გახდა 20 ან 100 გამზრდელი სხელა"
    },
    {
      "start": 195.72,
      "duration": 10.0,
      "text": "და ბოკვერი, რაც უფრო დიდი ლომი ხდებოდა,"
    },
    {
      "start": 201.12,
      "duration": 8.679,
      "text": "კატა თვალში მით უფრო ეპატარავებოდა."
    },
    {
      "start": 205.72,
      "duration": 7.96,
      "text": "თვალთ მაქცობსო გამზრდელი ვითომ ცოდნას"
    },
    {
      "start": 209.799,
      "duration": 7.561,
      "text": "მიყოფსო თორემ ჩემზე ჭკვიანი როგორ უნდა"
    },
    {
      "start": 213.68,
      "duration": 7.72,
      "text": "იყოსო კმარა თავის ჭკუაზე რაც აქამდე"
    },
    {
      "start": 217.36,
      "duration": 7.599,
      "text": "მატარა ჩემზე 10ჯერ 20ჯერ და უკვე 100ჯერ"
    },
    {
      "start": 221.4,
      "duration": 5.759,
      "text": "პატარამ ფიქრობდა"
    },
    {
      "start": 224.959,
      "duration": 5.721,
      "text": "და ერთხელაც"
    },
    {
      "start": 227.159,
      "duration": 8.561,
      "text": "ლომმა განგები ურჩა"
    },
    {
      "start": 230.68,
      "duration": 7.32,
      "text": "სუფრას წინა თათების დაუბანლად მიუჯდა"
    },
    {
      "start": 235.72,
      "duration": 7.56,
      "text": "გადამცა შენიშნა, დიდხანს როდი [მუსიკა]"
    },
    {
      "start": 238.0,
      "duration": 8.159,
      "text": "უთმინა, მაგრამ ლომმა ფასუხად"
    },
    {
      "start": 243.28,
      "duration": 6.36,
      "text": "მხოლოდ შემოუღრინა."
    },
    {
      "start": 246.159,
      "duration": 8.16,
      "text": "ღრენას მოჰყვა კამათი, რის ბოლოსაც"
    },
    {
      "start": 249.64,
      "duration": 7.679,
      "text": "სუფრიდან ლომი კატის გაზრდილი გამზრდელს"
    },
    {
      "start": 254.319,
      "duration": 3.0,
      "text": "წამოუფრინდა."
    },
    {
      "start": 257.4,
      "duration": 4.48,
      "text": "კატამ კარგად იცოდა, ლომთან შებმა არ"
    },
    {
      "start": 260.32,
      "duration": 3.8,
      "text": "ღირდა."
    },
    {
      "start": 261.88,
      "duration": 5.36,
      "text": "ღონით ვერ აჯობებდა, ვერც ხერხებით"
    },
    {
      "start": 264.12,
      "duration": 5.84,
      "text": "დაღლიდა, ამიტომაც [მუსიკა] გაიქცა,"
    },
    {
      "start": 267.24,
      "duration": 6.64,
      "text": "ფეხებს სთხოვა შეწევნა."
    },
    {
      "start": 269.96,
      "duration": 8.36,
      "text": "ლოვმაც არ დაახანა, უკან გამოედევნა. უცებ"
    },
    {
      "start": 273.88,
      "duration": 5.039,
      "text": "გადაირბინეს ეზო, მტელო ახორბენალი"
    },
    {
      "start": 278.32,
      "duration": 4.92,
      "text": "დუეტი [მუსიკა]"
    },
    {
      "start": 278.919,
      "duration": 6.12,
      "text": "ტყისპირს მიუახლოვდა და ზუსტად იმ"
    },
    {
      "start": 283.24,
      "duration": 5.08,
      "text": "მომენტში"
    },
    {
      "start": 285.039,
      "duration": 8.681,
      "text": "ლომი-ლამის რომ ეცა,"
    },
    {
      "start": 288.32,
      "duration": 9.08,
      "text": "კატა ხეზე ახტა და კენწეროზე მოექცა."
    },
    {
      "start": 293.72,
      "duration": 7.08,
      "text": "მოინდომა გაზრდილმაც მოქმედება ამგვარი,"
    },
    {
      "start": 297.4,
      "duration": 5.48,
      "text": "ახტა, მაგრამ მაშინვე ძირს მოიღო"
    },
    {
      "start": 300.8,
      "duration": 5.08,
      "text": "ბრაგვანი."
    },
    {
      "start": 302.88,
      "duration": 8.56,
      "text": "ასვლის შეუძლებლობა როცა გახდა ცალსახა"
    },
    {
      "start": 305.88,
      "duration": 9.48,
      "text": "ლომი იქვე მიწვა და კატას ტკბილად ასძახა"
    },
    {
      "start": 311.44,
      "duration": 9.12,
      "text": "რატომ ქენი მითხარი ნუ კი დამიმალავო"
    },
    {
      "start": 315.36,
      "duration": 7.8,
      "text": "ყველაფერი მასწავლე ხეზე ასვლა არაო"
    },
    {
      "start": 320.56,
      "duration": 6.079,
      "text": "ჩამოსძახა გამზრდელმა"
    },
    {
      "start": 323.16,
      "duration": 6.08,
      "text": "უმადურს და თავებას"
    },
    {
      "start": 326.639,
      "duration": 4.481,
      "text": "სწორედ დღეს ვაპირებდი შენთვის ამის"
    },
    {
      "start": 329.24,
      "duration": 5.48,
      "text": "სწავლებას"
    },
    {
      "start": 331.12,
      "duration": 7.799,
      "text": "მაგრამ მოიწ წადინე ჩვენი სკოლა არიო და"
    },
    {
      "start": 334.72,
      "duration": 6.52,
      "text": "ამიტომ ეს საქმე ვეღარ მოვასწარიო."
    },
    {
      "start": 338.919,
      "duration": 6.161,
      "text": "სხვასაც ბევრს ისწავლიდი შენთვის"
    },
    {
      "start": 341.24,
      "duration": 8.88,
      "text": "სასიკეთოსო. გულში მადლიერების მარცვალი"
    },
    {
      "start": 345.08,
      "duration": 7.36,
      "text": "რომ გედოსო. შენ კი იმის მაგივრად ჩემთვის"
    },
    {
      "start": 350.12,
      "duration": 8.4,
      "text": "გეგდო ყურიო."
    },
    {
      "start": 352.44,
      "duration": 10.36,
      "text": "ამჯობინე რომ იყო ასე უმადურიო."
    },
    {
      "start": 358.52,
      "duration": 6.28,
      "text": "თქვა კატამ და გადახტა სხვადა სხვა და"
    },
    {
      "start": 362.8,
      "duration": 5.399,
      "text": "სხვა ხეზე."
    },
    {
      "start": 364.8,
      "duration": 6.399,
      "text": "დარჩა ლომი ხის ძირში"
    },
    {
      "start": 368.199,
      "duration": 9.4,
      "text": "სინანულით სახეზე."
    },
    {
      "start": 371.199,
      "duration": 9.241,
      "text": "აქ ზღაპარიც მორჩა და სად იყო და სად არა,"
    },
    {
      "start": 377.599,
      "duration": 5.44,
      "text": "შენი ძილიც მოფრინდა,"
    },
    {
      "start": 380.44,
      "duration": 10.08,
      "text": "მეგობარო პატარა."
    },
    {
      "start": 383.039,
      "duration": 9.56,
      "text": "აი უკვე მსუბუქ და ლამაზ ფრთაზეც შეგისვა"
    },
    {
      "start": 390.52,
      "duration": 3.76,
      "text": "იავ ნანა"
    },
    {
      "start": 392.599,
      "duration": 6.281,
      "text": "ნანინა"
    },
    {
      "start": 394.28,
      "duration": 4.6,
      "text": "ტკბილი ძილი ნებისა"
    },
    {
      "start": 408.069,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 415.274,
      "duration": 2.02,
      "text": "[მუსიკა]"
    },
    {
