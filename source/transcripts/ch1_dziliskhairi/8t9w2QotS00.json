{
  "id": "8t9w2QotS00",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 4.52,
      "duration": 6.079,
      "text": "ზამთარია,"
    },
    {
      "start": 6.16,
      "duration": 8.559,
      "text": "ცივა და ბუხართან მიკუნტულა ჩვენი დუდუ"
    },
    {
      "start": 10.599,
      "duration": 8.561,
      "text": "კურდღელი, ანუ ჩვენი დუდუნა."
    },
    {
      "start": 14.719,
      "duration": 6.241,
      "text": "ჟოზე უხმობს გარედან, დუდუ, გარეთ გამო"
    },
    {
      "start": 19.16,
      "duration": 5.92,
      "text": "თოვს"
    },
    {
      "start": 20.96,
      "duration": 6.719,
      "text": "ცოტა ვიციგაოთ და ბევრი ვიგუნდაოთო."
    },
    {
      "start": 25.08,
      "duration": 6.119,
      "text": "დუდუნა კი იძახის"
    },
    {
      "start": 27.679,
      "duration": 8.121,
      "text": "ვერ გამოვალ იცი მე სულ არ მიყვარს ეგ"
    },
    {
      "start": 31.199,
      "duration": 8.641,
      "text": "თოვლი ყინული და სიცივე და ლოლუა სტაფილოს"
    },
    {
      "start": 35.8,
      "duration": 7.84,
      "text": "რომ წააგავს გინახავს მე დღეს ვნახე და"
    },
    {
      "start": 39.84,
      "duration": 7.32,
      "text": "კბილი მოვიტეხე კინაღამ ასე გრძელი რად"
    },
    {
      "start": 43.64,
      "duration": 5.8,
      "text": "არის როდის გავა ზამთარი გაზაფხული"
    },
    {
      "start": 47.16,
      "duration": 4.16,
      "text": "[ჩახველება] მიყვარსო ნეტავ ვინ"
    },
    {
      "start": 49.44,
      "duration": 5.599,
      "text": "მომიყვანსო"
    },
    {
      "start": 51.32,
      "duration": 8.199,
      "text": "ჟოზემ უთხრა წუწუნით აღარ დაიღალეო"
    },
    {
      "start": 55.039,
      "duration": 8.36,
      "text": "გაზაფხული გიყვარს და ისიც მოვა მალეო."
    },
    {
      "start": 59.519,
      "duration": 7.761,
      "text": "მართლაც ადრე თუ გვიან, ახლოდან [მუსიკა]"
    },
    {
      "start": 63.399,
      "duration": 7.161,
      "text": "თუ შორიდან, როგორც ჟოზე დაგვპირდა,"
    },
    {
      "start": 67.28,
      "duration": 7.28,
      "text": "გაზაფხულიც [მუსიკა] მოვიდა. მერე ჟოზეც"
    },
    {
      "start": 70.56,
      "duration": 7.96,
      "text": "მოვიდა და დუდუნას ეძახის დუდუ ნახე"
    },
    {
      "start": 74.56,
      "duration": 7.8,
      "text": "ტოტები გაიფოთ ყველა ხის გამოდი და"
    },
    {
      "start": 78.52,
      "duration": 6.36,
      "text": "მიხვდები მზემ და სითბო მიმატა. ხან"
    },
    {
      "start": 82.36,
      "duration": 6.399,
      "text": "ყვავილი ვყნოსოთ და ხან ვიცეკვოთ"
    },
    {
      "start": 84.88,
      "duration": 7.44,
      "text": "წვიმასთან. ეს პასუხობს. ზამთარში"
    },
    {
      "start": 88.759,
      "duration": 5.881,
      "text": "გადავურჩი ყინვებსო, მაგრამ ახლა ყვავილის"
    },
    {
      "start": 92.32,
      "duration": 6.72,
      "text": "მტვერზე მაცემინებსო."
    },
    {
      "start": 94.64,
      "duration": 6.519,
      "text": "წვიმაში კი ეს წვიმა რა ყოფილა ასეთი,"
    },
    {
      "start": 99.04,
      "duration": 5.759,
      "text": "რამდენჯერაც გავედი, იმდენჯერვე"
    },
    {
      "start": 101.159,
      "duration": 6.841,
      "text": "დავსველდი. ერთი სიტყვით ვერაფრით ვერ"
    },
    {
      "start": 104.799,
      "duration": 7.201,
      "text": "გამოვალ ჟოზეო. ნეტავ ეს გაზაფხული"
    },
    {
      "start": 108.0,
      "duration": 7.04,
      "text": "გავიდოდეს დროზეო. მე ზაფხული მიყვარსო,"
    },
    {
      "start": 112.0,
      "duration": 6.479,
      "text": "მაგრამ ვინ მომიყვანსო?"
    },
    {
      "start": 115.04,
      "duration": 7.64,
      "text": "ჟოზემ უთხრა, წუწუნით აღარ დაიღალეო,"
    },
    {
      "start": 118.479,
      "duration": 7.64,
      "text": "გყვარებია ზაფხული, ხოდა მოვა მალეო."
    },
    {
      "start": 122.68,
      "duration": 6.6,
      "text": "მართლაც, ადრე თუ გვიან, ახლოდან თუ"
    },
    {
      "start": 126.119,
      "duration": 6.521,
      "text": "შორიდან, ჟირაფი რომ დაგვპირდა, ის"
    },
    {
      "start": 129.28,
      "duration": 6.959,
      "text": "ზაფხული მოვიდა. მერე ჟოზეც მოვიდა, დუდუს"
    },
    {
      "start": 132.64,
      "duration": 7.0,
      "text": "უხმობს, სად ხარო? რომ ნატრობდი, იმისი"
    },
    {
      "start": 136.239,
      "duration": 6.481,
      "text": "მოსვლა უნდა გახარო. ვიწუწაოთ ეზოში და"
    },
    {
      "start": 139.64,
      "duration": 7.56,
      "text": "გავგრილდეთ ასეო, თუნდაც გავისეირნოთ"
    },
    {
      "start": 142.72,
      "duration": 7.44,
      "text": "მთაში ან და ზღვაზეო. დუდუნა კი პასუხობს,"
    },
    {
      "start": 147.2,
      "duration": 6.2,
      "text": "ვერ გამოვალ ვერაო, ნაბიჯსაც ვერ"
    },
    {
      "start": 150.16,
      "duration": 6.4,
      "text": "გადავდგამ გარეთ ისე ცხელაო. მეტკინება"
    },
    {
      "start": 153.4,
      "duration": 6.08,
      "text": "თავი და გამიშრება ყელიო. სახლში ცოტას"
    },
    {
      "start": 156.56,
      "duration": 6.56,
      "text": "მაგრილებს კონდიციონერიო. სხვა დროისთვის"
    },
    {
      "start": 159.48,
      "duration": 7.2,
      "text": "გადავდოთ სეირნობა ჟოზეო. ნეტავი ეს"
    },
    {
      "start": 163.12,
      "duration": 6.56,
      "text": "ზაფხული გავიდოეს დროზეო."
    },
    {
      "start": 166.68,
      "duration": 5.0,
      "text": "შემოდგომა მიყვარსო, მაგრამ ვინ"
    },
    {
      "start": 169.68,
      "duration": 5.72,
      "text": "მომიყვანსო?"
    },
    {
      "start": 171.68,
      "duration": 7.72,
      "text": "ჟოზემ უთხრა: წუწუნით რად არ დაიღალეო,"
    },
    {
      "start": 175.4,
      "duration": 7.6,
      "text": "შემოდგომა ხომ გიყვარს? ჰოდა მოვა მალეო."
    },
    {
      "start": 179.4,
      "duration": 6.839,
      "text": "მართლაც ადრე თუ გვიან, ახლოდან თუ"
    },
    {
      "start": 183.0,
      "duration": 7.159,
      "text": "შორიდან, როგორც ჟოზე დაგვპირდა,"
    },
    {
      "start": 186.239,
      "duration": 7.481,
      "text": "შემოდგომა მოვიდა. მერე ჟოზეც მოვიდა და"
    },
    {
      "start": 190.159,
      "duration": 6.08,
      "text": "ეძახის მეგობარს გამოდიო დუდუნა სახლში"
    },
    {
      "start": 193.72,
      "duration": 6.2,
      "text": "ჯდომა გეყოფა შენი ხელით არ გინდა"
    },
    {
      "start": 196.239,
      "duration": 7.161,
      "text": "მწიფეხილის მოწყვეტა ვითამაშოთ ფერებთან"
    },
    {
      "start": 199.92,
      "duration": 7.52,
      "text": "ჭრევალაჭრულა ფოთლებთან ეს პასუხობს"
    },
    {
      "start": 203.4,
      "duration": 7.28,
      "text": "ჟოზიკო მეც მაგას ვემალები წითელ-ყვითელ"
    },
    {
      "start": 207.44,
      "duration": 7.04,
      "text": "ფერებზე მიჭრელდება თვალები ხილს და"
    },
    {
      "start": 210.68,
      "duration": 8.08,
      "text": "ფოთოლს სახეში მე მომაყრის სულ ყველას ან"
    },
    {
      "start": 214.48,
      "duration": 8.0,
      "text": "მეც ცაში გამაფრენს ქარი ისე უბერავს"
    },
    {
      "start": 218.76,
      "duration": 7.679,
      "text": "ერთი სიტყვით ვერაფრით ვერ გამოვალ ჟოზეო."
    },
    {
      "start": 222.48,
      "duration": 8.8,
      "text": "ნეტავ ეს შემოდგომა გავიდოდეს დროზეო. მე"
    },
    {
      "start": 226.439,
      "duration": 9.681,
      "text": "ზამთარი მიყვარსო მაგრამ ვინ მომიყვანსო."
    },
    {
      "start": 231.28,
      "duration": 7.92,
      "text": "ეს წამოცდა დუდუნას და ენაზე იკბინა."
    },
    {
      "start": 236.12,
      "duration": 7.28,
      "text": "ჟოზეს კიდევ მობეზრდა რაც აქამდე ითმინა."
    },
    {
      "start": 239.2,
      "duration": 8.48,
      "text": "ასე უთხრა მისმინე ჩემო კარგო დუდუნა. შენ"
    },
    {
      "start": 243.4,
      "duration": 7.759,
      "text": "დუდუნა კი არა უნდა გერქვას წუწუნა. მთელი"
    },
    {
      "start": 247.68,
      "duration": 6.6,
      "text": "წელი წუწუნებ, უქმადზე ხარ თან სულში,"
    },
    {
      "start": 251.159,
      "duration": 6.521,
      "text": "გაზაფხულზე, ზამთარში, შემოდგომით,"
    },
    {
      "start": 254.28,
      "duration": 6.16,
      "text": "ზაფხულში არ გინდა, რომ ნიავით, მზით ან"
    },
    {
      "start": 257.68,
      "duration": 7.2,
      "text": "წვიმით გაერთო შენ არცერთი სეზონი არ"
    },
    {
      "start": 260.44,
      "duration": 8.319,
      "text": "გიყვარსო საერთოდ. ამ დროს მზეა, თოვაა,"
    },
    {
      "start": 264.88,
      "duration": 5.4,
      "text": "წვიმაა თუ ქარია, ყველა ბუნებრივია, ყველა"
    },
    {
      "start": 268.759,
      "duration": 5.641,
      "text": "მეგობარია."
    },
    {
      "start": 270.28,
      "duration": 7.919,
      "text": "ოღონდ ის შენ ამისიც უნდა იყო მცოდნეო,"
    },
    {
      "start": 274.4,
      "duration": 7.72,
      "text": "მაშინ გემეგობრება შენ თუ ემეგობრეო."
    },
    {
      "start": 278.199,
      "duration": 6.44,
      "text": "დაირცხვინა დუდუნამ. მართალი ხარ ჟოზეო."
    },
    {
      "start": 282.12,
      "duration": 6.6,
      "text": "რა ცუდია მე თვითონ რომ ვერ მივხვდი"
    },
    {
      "start": 284.639,
      "duration": 7.241,
      "text": "დროზეო. მზე იქნება წვიმა თუ ნამქერი და"
    },
    {
      "start": 288.72,
      "duration": 7.319,
      "text": "ქარიო. დღეიდან მეც ვიქნები მათი"
    },
    {
      "start": 291.88,
      "duration": 8.159,
      "text": "მეგობარიო, თქვა დუდუმ და მას შემდეგ"
    },
    {
      "start": 296.039,
      "duration": 7.681,
      "text": "მართლა ასე ხდებოდა. დუდუ ყინვას ქურქით"
    },
    {
      "start": 300.039,
      "duration": 6.681,
      "text": "და წვიმას ქოლგით ხვდებოდა. ზაფხულში კი"
    },
    {
      "start": 303.72,
      "duration": 7.0,
      "text": "სიცხეებს რომ არ ჩამოეღვენთა, ჩალის ქუდი"
    },
    {
      "start": 306.72,
      "duration": 8.039,
      "text": "ეხურა, მზის სათვალე ეკეთა. შემოდგომით,"
    },
    {
      "start": 310.72,
      "duration": 8.199,
      "text": "სად იყო ან მოწყენა ან სევდა, ჭრელჭრელ"
    },
    {
      "start": 314.759,
      "duration": 7.961,
      "text": "ფოთლებს დუდუნა სულ კისკისით დასდევდა."
    },
    {
      "start": 318.919,
      "duration": 8.12,
      "text": "დღისით სადღა ეცალა, რომ რამეზე ედარდა."
    },
    {
      "start": 322.72,
      "duration": 6.16,
      "text": "ღამით ტკბილად ეძინა, ლამაზ სიზმრებს"
    },
    {
      "start": 327.039,
      "duration": 6.841,
      "text": "ხედავდა."
    },
    {
      "start": 328.88,
      "duration": 9.24,
      "text": "აქ ზღაპარი მორჩა და სად იყო და სად არა,"
    },
    {
      "start": 333.88,
      "duration": 10.12,
      "text": "შენი ძილიც მოფრინდა, მეგობარო პატარა."
    },
    {
      "start": 338.12,
      "duration": 9.6,
      "text": "აი უკვე მსუბუქ და ლამაზ ფთაზეც შეგისვა."
    },
    {
      "start": 344.0,
      "duration": 9.0,
      "text": "იავ ნანა ნანინა"
    },
    {
      "start": 347.72,
      "duration": 5.28,
      "text": "ტკბილი ძილი ნებისა."
    },
    {
      "start": 378.594,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    }
  ]
}