{
  "id": "Tdc1TVNJHgU",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 1.439,
      "duration": 8.681,
      "text": "ამ დებს დღემდე თუ არ იცნობთ, გაიცანით"
    },
    {
      "start": 5.44,
      "duration": 9.84,
      "text": "სანამ დროა. უფროსი და თებროლეა, უმცროსი"
    },
    {
      "start": 10.12,
      "duration": 9.36,
      "text": "და თანოა, თუმცა ერთიც და მეორეც ციცქნაა"
    },
    {
      "start": 15.28,
      "duration": 8.3,
      "text": "და საყვარელი, მქნელი ყველა ონავრობის,"
    },
    {
      "start": 19.48,
      "duration": 7.119,
      "text": "რასაც ელი ან არ ელი. ერთხელ დებმა"
    },
    {
      "start": 23.58,
      "duration": 5.38,
      "text": "[მუსიკა] მოინდომეს ხალხის ალაპარაკება და"
    },
    {
      "start": 26.599,
      "duration": 5.761,
      "text": "ამისთვის გადაწყვიტეს"
    },
    {
      "start": 28.96,
      "duration": 6.72,
      "text": "იმ კარადის დალაგება მაღალ ჭერს რომ"
    },
    {
      "start": 32.36,
      "duration": 8.12,
      "text": "ებჯინება უჯრებით და თაროებით და თუ"
    },
    {
      "start": 35.68,
      "duration": 9.039,
      "text": "ფიქრობთ ეს არ არის საქმე თებრო თანოების"
    },
    {
      "start": 40.48,
      "duration": 7.64,
      "text": "იმიტომ რომ არ გინახავთ თებროს შოუ"
    },
    {
      "start": 44.719,
      "duration": 6.68,
      "text": "საოცრება ერთ კარში რომ შეძვრება და"
    },
    {
      "start": 48.12,
      "duration": 4.56,
      "text": "მეორედან გამოძვრება საქმე მაინც თუ"
    },
    {
      "start": 51.399,
      "duration": 5.081,
      "text": "გაძნელ"
    },
    {
      "start": 52.68,
      "duration": 8.719,
      "text": "იოლდება შემდეგ ასე, სადაც თებრო ვერ"
    },
    {
      "start": 56.48,
      "duration": 6.84,
      "text": "ეტევა, თანომდის შეტევაზე. ერთი სიტყვით,"
    },
    {
      "start": 61.399,
      "duration": 5.76,
      "text": "რასაც მისწვდნენ, [მუსიკა]"
    },
    {
      "start": 63.32,
      "duration": 7.799,
      "text": "მოუარეს სწრაფად ყოველს და კარადას"
    },
    {
      "start": 67.159,
      "duration": 8.201,
      "text": "ეშმაკურად თვალი მაღლა ააყოლეს, სადაც"
    },
    {
      "start": 71.119,
      "duration": 7.441,
      "text": "ცალკე სამყაროა თაროებად დაქსელი და"
    },
    {
      "start": 75.36,
      "duration": 7.32,
      "text": "თებროლე პირველ თაროს დაეკიდა"
    },
    {
      "start": 78.56,
      "duration": 9.28,
      "text": "მთასვლელივით. არც თანომ დააყოვნა. გზას"
    },
    {
      "start": 82.68,
      "duration": 7.439,
      "text": "აუყვა რაზმი სრული კიდევ კარგი კარადა რომ"
    },
    {
      "start": 87.84,
      "duration": 5.84,
      "text": "კედელზეა მილურსმული"
    },
    {
      "start": 90.119,
      "duration": 5.28,
      "text": "ამ დროს უკვე ხმაც გავარდა ატყდა ხალხში"
    },
    {
      "start": 93.68,
      "duration": 6.56,
      "text": "მითქმა-მოთქმა"
    },
    {
      "start": 95.399,
      "duration": 7.321,
      "text": "ზოგმა თებროს გარჯაქო თანო უფრო აქო ზოგმა"
    },
    {
      "start": 100.24,
      "duration": 7.32,
      "text": "ოღონდ ერთხმად იოცებდნენ სოფლები და"
    },
    {
      "start": 102.72,
      "duration": 7.039,
      "text": "ქალაქები ეს რა ხდება ცელქი დები დიდ"
    },
    {
      "start": 107.56,
      "duration": 4.44,
      "text": "კარადას ალაგებენ"
    },
    {
      "start": 109.759,
      "duration": 5.72,
      "text": "თუმცა იყო ვიღაც"
    },
    {
      "start": 112.0,
      "duration": 6.88,
      "text": "დივნის საზურგეზე შემომჯდარი ამ მსოფლიო"
    },
    {
      "start": 115.479,
      "duration": 8.0,
      "text": "საოცრებას რომ მზვერავდა ეჭვის თვალით."
    },
    {
      "start": 118.88,
      "duration": 8.239,
      "text": "თუკი მართლა ავაგებენ კრუტუნებდა კატატია,"
    },
    {
      "start": 123.479,
      "duration": 7.12,
      "text": "მაშ ყველაფერს კარატიდან ნიატაკზე რატომ"
    },
    {
      "start": 127.119,
      "duration": 7.321,
      "text": "ყრიან? ამ ურწმუნოს ჩამოსძახეს, [მუსიკა]"
    },
    {
      "start": 130.599,
      "duration": 7.761,
      "text": "გაგივიდა თავს ძალიან სასწაული. თებროს"
    },
    {
      "start": 134.44,
      "duration": 6.76,
      "text": "თანოს დალაგებას გვასწავლიან. ნათქვამია,"
    },
    {
      "start": 138.36,
      "duration": 6.04,
      "text": "უსაქმურებს უყვართ ფუჭი ხმაურიო. [მუსიკა]"
    },
    {
      "start": 141.2,
      "duration": 6.44,
      "text": "იმისთვის, რომ დაალაგო, ჯერ ხომ უნდა"
    },
    {
      "start": 144.4,
      "duration": 6.16,
      "text": "აურიო. ვისაც ეს ვერ შეუგნია, [მუსიკა]"
    },
    {
      "start": 147.64,
      "duration": 5.72,
      "text": "შენიშვნასაც ნუღარ ბედავს და ბეჯითად"
    },
    {
      "start": 150.56,
      "duration": 5.2,
      "text": "მიუბრუნდნენ დალაგების პირველ ეტაპს."
    },
    {
      "start": 153.36,
      "duration": 6.32,
      "text": "განაგრძობდნენ გაოცებას სოფლები და"
    },
    {
      "start": 155.76,
      "duration": 7.839,
      "text": "ქალაქები, თებროლე და ციცქნა თანო დიდ"
    },
    {
      "start": 159.68,
      "duration": 8.16,
      "text": "კარადას ალაგებენ და მანამდე მატულობდა ამ"
    },
    {
      "start": 163.599,
      "duration": 7.241,
      "text": "ამბავზე რეაქცია, ამ ამბავმა ვიდრე დედის"
    },
    {
      "start": 167.84,
      "duration": 7.64,
      "text": "ყურამდეც არ მიაღწია. თუ იკითხავთ"
    },
    {
      "start": 170.84,
      "duration": 8.319,
      "text": "რანაირად, თურმე სწორედ ამ დროს დედა იქვე"
    },
    {
      "start": 175.48,
      "duration": 6.759,
      "text": "სამზარეულოში რძიან ფაფას ამზადებდა. თან"
    },
    {
      "start": 179.159,
      "duration": 6.8,
      "text": "ორიდან ერთი ყური ჰქონდა ტელევიზორისკენ"
    },
    {
      "start": 182.239,
      "duration": 8.601,
      "text": "და ის იყო მოიწონა ფაფის ფერი, გემო,"
    },
    {
      "start": 185.959,
      "duration": 9.2,
      "text": "სისქე, რომ იმ ყურში შემოესმა, თუმცლეს"
    },
    {
      "start": 190.84,
      "duration": 7.36,
      "text": "არგავსო თანანო და თებრო მართლა ალაგებენ"
    },
    {
      "start": 195.159,
      "duration": 7.761,
      "text": "კარადასო. დედას კოვზი [მუსიკა] გაუვარდა,"
    },
    {
      "start": 198.2,
      "duration": 9.36,
      "text": "იმისთანაეცა ელდა, დების ოთახს მიეპარა და"
    },
    {
      "start": 202.92,
      "duration": 8.519,
      "text": "შიგ ფრთხილად შეიხედა. დაინახა, რომ ღიაა"
    },
    {
      "start": 207.56,
      "duration": 8.319,
      "text": "ყველა უჯრა, ყველა კარი და იმხელა"
    },
    {
      "start": 211.439,
      "duration": 8.401,
      "text": "კარადაში არაფერი აღარ არის. ტანსაცმელი"
    },
    {
      "start": 215.879,
      "duration": 8.761,
      "text": "თეთრეული რითაც იყო წინად სავსე კარადიდან"
    },
    {
      "start": 219.84,
      "duration": 9.64,
      "text": "გაფრენილა დაფენილა იატაკზე დაზედ უკვე"
    },
    {
      "start": 224.64,
      "duration": 7.239,
      "text": "არხეინად გემრიელად თბილად რბილად აქეთ"
    },
    {
      "start": 229.48,
      "duration": 4.039,
      "text": "თებროკო ტრიალობს [მუსიკა] იქით"
    },
    {
      "start": 231.879,
      "duration": 4.041,
      "text": "თანომიწოლილა"
    },
    {
      "start": 233.519,
      "duration": 5.72,
      "text": "ასე მორჩა დედის შიში ნეტა ვიქრა"
    },
    {
      "start": 235.92,
      "duration": 6.399,
      "text": "დამხვდებაო უკვე ნახა რაც ხდებოდა და"
    },
    {
      "start": 239.239,
      "duration": 5.441,
      "text": "იკითხა რა ხდებაო"
    },
    {
      "start": 242.319,
      "duration": 5.241,
      "text": "დებს თვალები გაუბრწყინდათ [მუსიკა]"
    },
    {
      "start": 244.68,
      "duration": 6.839,
      "text": "კარგია, რომ გცალიაო. დიდ კარადას"
    },
    {
      "start": 247.56,
      "duration": 7.28,
      "text": "ვალაგებდით, დავიღალეთ ძალიანო. მთავარია"
    },
    {
      "start": 251.519,
      "duration": 6.44,
      "text": "მუშაობა როგორ უნდა განახეთო. ხოდა ახლა"
    },
    {
      "start": 254.84,
      "duration": 6.6,
      "text": "უკვე დროა შენც რაღაცა გააკეთო. რაღა"
    },
    {
      "start": 257.959,
      "duration": 5.96,
      "text": "დარჩა დედიკუნა? კი აუხვალ შენ ამდენსო."
    },
    {
      "start": 261.44,
      "duration": 4.08,
      "text": "რაც იქიდან გამოვყარეთ, უკან უნდა"
    },
    {
      "start": 263.919,
      "duration": 6.12,
      "text": "შელაგდესო."
    },
    {
      "start": 265.52,
      "duration": 6.08,
      "text": "თქვეს გვერდები იცვალეს და რომ მოეწყვნენ"
    },
    {
      "start": 270.039,
      "duration": 5.321,
      "text": "უფრო თბილად, [მუსიკა]"
    },
    {
      "start": 271.6,
      "duration": 5.4,
      "text": "მუშაობით გადაღლილებს იქვე ტკბილად"
    },
    {
      "start": 275.36,
      "duration": 5.399,
      "text": "მიეძინათ."
    },
    {
      "start": 277.0,
      "duration": 8.52,
      "text": "ასე მორჩა ზღაპარი და სად იყო [მუსიკა] და"
    },
    {
      "start": 280.759,
      "duration": 9.16,
      "text": "სად არაო? შენი ძილიც მოფრენილა, მეგობარო"
    },
    {
      "start": 285.52,
      "duration": 6.32,
      "text": "პატარაო. აი უკვე შემოგხვია სიყვარულის"
    },
    {
      "start": 289.919,
      "duration": 3.921,
      "text": "ფრთებიცაო."
    },
    {
      "start": 291.84,
      "duration": 4.12,
      "text": "იავნანა"
    },
    {
      "start": 293.84,
      "duration": 7.079,
      "text": "ვარდოვნანა"
    },
    {
      "start": 295.96,
      "duration": 4.959,
      "text": "ტკბილი ძილი ნებისაო"
    },
    {
      "start": 318.988,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    }
  ]
}