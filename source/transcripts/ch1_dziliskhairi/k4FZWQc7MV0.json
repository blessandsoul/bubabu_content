{
  "id": "k4FZWQc7MV0",
  "lang": "ka",
  "auto": true,
  "snippets": [
    {
      "start": 3.24,
      "duration": 7.08,
      "text": "ერთხელ ჟოზემ გადაწყვიტა, სახლში ჯდომას"
    },
    {
      "start": 7.2,
      "duration": 6.24,
      "text": "ჯობია, რომ წავიდე და მთელი ჩემი"
    },
    {
      "start": 10.32,
      "duration": 7.32,
      "text": "საქართველო მოვიარო, რომ სხვადასხვა კუთხე"
    },
    {
      "start": 13.44,
      "duration": 8.24,
      "text": "მხარის სოფელ ქალაქ ვაკემთებში გავარკვიო"
    },
    {
      "start": 17.64,
      "duration": 7.32,
      "text": "თუ მათ შორის რომელია უკეთესი. ზღაპარში"
    },
    {
      "start": 21.68,
      "duration": 5.96,
      "text": "არ გაჭირდება საქმე მალე მოვილიო. თან"
    },
    {
      "start": 24.96,
      "duration": 6.04,
      "text": "ქვეყანაც პატარა გვაქვს, საღამომდე"
    },
    {
      "start": 27.64,
      "duration": 8.2,
      "text": "მოვივლიო. სულ პირველად ქართლს [მუსიკა]"
    },
    {
      "start": 31.0,
      "duration": 11.36,
      "text": "ეწვია ხილით სავსე ტოტებ გაშლილს, კრიფა"
    },
    {
      "start": 35.84,
      "duration": 10.719,
      "text": "ბალი, მსხალი კომში ატამი და ბევრი ვაშლი."
    },
    {
      "start": 42.36,
      "duration": 7.32,
      "text": "ახლა დროა შეიმოწმოს ფანდი, ხერხი, ძალა,"
    },
    {
      "start": 46.559,
      "duration": 7.0,
      "text": "ჯანი და [მუსიკა] ამისთვის მოუყვანეს"
    },
    {
      "start": 49.68,
      "duration": 6.65,
      "text": "მთელი ქვეყნის ფალავანი. გაამხნევეს,"
    },
    {
      "start": 53.559,
      "duration": 6.401,
      "text": "დარდი ნუ გაქვს თავი ამას მიანდეო."
    },
    {
      "start": 56.33,
      "duration": 5.15,
      "text": "[მუსიკა] ეს გასწავლის უფრო კარგად როგორ"
    },
    {
      "start": 59.96,
      "duration": 5.0,
      "text": "გადაყირავდეო."
    },
    {
      "start": 61.48,
      "duration": 7.76,
      "text": "ჟოზეს ისე ეღიმება, მგონი ფიქრობს უკვე"
    },
    {
      "start": 64.96,
      "duration": 8.96,
      "text": "ასე, ალბათ ქართლი უკეთესი კუთხეო სულ"
    },
    {
      "start": 69.24,
      "duration": 8.8,
      "text": "ყველაზე მერე ნახა კახეთი და ავთვალს არც"
    },
    {
      "start": 73.92,
      "duration": 8.64,
      "text": "ის ენახვება. გაფენილა ველებად და რა თქმა"
    },
    {
      "start": 78.04,
      "duration": 9.039,
      "text": "უნდა ვენახებად. რომ იგემა აქ ყურძენი, იქ"
    },
    {
      "start": 82.56,
      "duration": 7.879,
      "text": "თათარა ჩურჩხელაო, თქვა, კახეთიც სულ"
    },
    {
      "start": 87.079,
      "duration": 8.561,
      "text": "ყველაზე უკეთესი კუთხეო. უკვე აღმართს"
    },
    {
      "start": 90.439,
      "duration": 8.801,
      "text": "მიუყვება. აი ამას ჰქვია ხედი. ეგებება"
    },
    {
      "start": 95.64,
      "duration": 7.72,
      "text": "აღმოსავლეთ საქართველოს მთიანეთი. ჟოზე"
    },
    {
      "start": 99.24,
      "duration": 7.76,
      "text": "ცდილობს დაეტოლოს მუდამ მაგარს, მუდამ"
    },
    {
      "start": 103.36,
      "duration": 6.32,
      "text": "მაღალს, თუშეთ პანკის ფშავხევსურეთ,"
    },
    {
      "start": 107.0,
      "duration": 6.52,
      "text": "ხევმთიულეთ გუდამაყარს."
    },
    {
      "start": 109.68,
      "duration": 8.52,
      "text": "ასე ამბობს, არც გვენახოს ამ მთაგორის"
    },
    {
      "start": 113.52,
      "duration": 8.239,
      "text": "გალევაო, რადგან ესეც სულ ყველაზე უკეთესი"
    },
    {
      "start": 118.2,
      "duration": 5.959,
      "text": "მხარეაო. მერე სამცხე-ჯავახეთის მიწისაკენ"
    },
    {
      "start": 121.759,
      "duration": 7.321,
      "text": "გასწია, [მუსიკა] რომ ძველი დიდი"
    },
    {
      "start": 124.159,
      "duration": 9.521,
      "text": "მეფესავით ბრძანოს აქა ვარ ძიაო. მოეფეროს"
    },
    {
      "start": 129.08,
      "duration": 8.68,
      "text": "მესხურ მიწას, კლდეში ნაკვეთ ლამაზ მით"
    },
    {
      "start": 133.68,
      "duration": 8.44,
      "text": "ქვაბულში შევიდეს და მეორედან გამოვიდეს."
    },
    {
      "start": 137.76,
      "duration": 8.36,
      "text": "ხოლო ბოლოს შეასრულოს დადგენილი უკვე წესი"
    },
    {
      "start": 142.12,
      "duration": 5.8,
      "text": "და შეარქვას ამ კუთხესაც სულ ყველაზე"
    },
    {
      "start": 146.12,
      "duration": 5.6,
      "text": "უკეთესი."
    },
    {
      "start": 147.92,
      "duration": 9.08,
      "text": "ჩამოვიდა აჭარაში. არც აქ დაუგვიანია. ეს"
    },
    {
      "start": 151.72,
      "duration": 8.4,
      "text": "აჭარა ერთდროულად მთიანი და ზღვიანია."
    },
    {
      "start": 157.0,
      "duration": 6.959,
      "text": "ზღვა არ ჰქონდა ნანახი და ავისრულე"
    },
    {
      "start": 160.12,
      "duration": 6.32,
      "text": "ოცნებაო. რა მსიღრმია, რომ შევიდე"
    },
    {
      "start": 163.959,
      "duration": 6.36,
      "text": "ნიკაპამდე მომწვდებაო."
    },
    {
      "start": 166.44,
      "duration": 7.159,
      "text": "მერე ისე ოსტატურად დაუარა აჭარული,"
    },
    {
      "start": 170.319,
      "duration": 7.56,
      "text": "ააცეკვა კენჭი, პალმა, დელფინი და"
    },
    {
      "start": 173.599,
      "duration": 7.881,
      "text": "ხაჭაპური. ამის მერე აჭარასაც მეტი რა გზა"
    },
    {
      "start": 177.879,
      "duration": 5.801,
      "text": "ექნებოდა იმის გარდა, სულ ყველაზე კარგი"
    },
    {
      "start": 181.48,
      "duration": 6.399,
      "text": "კუთხე შერქმეოდა."
    },
    {
      "start": 183.68,
      "duration": 8.839,
      "text": "აქ კი ჟოზე ფეხსაცმელი გაიხადე [მუსიკა]"
    },
    {
      "start": 187.879,
      "duration": 6.041,
      "text": "ისე შედი მეტისმეტად კულტურული გელოდება"
    },
    {
      "start": 192.519,
      "duration": 4.921,
      "text": "იმერეთი [მუსიკა]"
    },
    {
      "start": 193.92,
      "duration": 5.239,
      "text": "მობრძანდითო შებრძანდითო მიბრძანდითო"
    },
    {
      "start": 197.44,
      "duration": 5.24,
      "text": "დაბრძანდითო"
    },
    {
      "start": 199.159,
      "duration": 7.041,
      "text": "ვინც კი შეხვდა რაც კი შეხვდა ყველამ"
    },
    {
      "start": 202.68,
      "duration": 6.639,
      "text": "უთხრა თითო-თითო მიტომ არის დინოზავრის"
    },
    {
      "start": 206.2,
      "duration": 8.399,
      "text": "ნაკვალებთან მხნედ რომ მიდის ფეხის ჩლიქი"
    },
    {
      "start": 209.319,
      "duration": 8.961,
      "text": "დაატოლა ყოფილაო ცოტა დიდი"
    },
    {
      "start": 214.599,
      "duration": 7.84,
      "text": "ერეთიც იხსენება უკვე ასე საქართველოს"
    },
    {
      "start": 218.28,
      "duration": 7.959,
      "text": "კიდევ ერთი კარგი კუთხე სულ ყველაზე"
    },
    {
      "start": 222.439,
      "duration": 7.16,
      "text": "ბარემო ვთქვათ რომ ასეთივე ჩვენი ჟოზეს"
    },
    {
      "start": 226.239,
      "duration": 8.801,
      "text": "ურყევებით გამოცხადდა მომავალში შემოვლილი"
    },
    {
      "start": 229.599,
      "duration": 9.081,
      "text": "კუთხეებიც გურიაში რა მთებია რა ჰაერი რა"
    },
    {
      "start": 235.04,
      "duration": 7.399,
      "text": "ბალახი გემრიელი ჩაიასვეს მოახურეს"
    },
    {
      "start": 238.68,
      "duration": 7.399,
      "text": "ყაბალახი მოფერების ეს უნარი რაჭალეჩ"
    },
    {
      "start": 242.439,
      "duration": 8.321,
      "text": "ჩხუმს ვინ აჩუქა? ძვირფას სტუმარს რომ"
    },
    {
      "start": 246.079,
      "duration": 8.88,
      "text": "უძახა სულ ჟოზუკა ჟირაფუკა. სვანეთშიც არ"
    },
    {
      "start": 250.76,
      "duration": 7.719,
      "text": "დაამალეს არც ალერსი და არც ბინა. ისეთ"
    },
    {
      "start": 254.959,
      "duration": 7.601,
      "text": "კოშკში დაპატიჟეს კისერი ვერ ააწვდინა."
    },
    {
      "start": 258.479,
      "duration": 7.401,
      "text": "ჟოზე უშბას ეუბნება, ვიცი უნდა დამღალოო."
    },
    {
      "start": 262.56,
      "duration": 7.76,
      "text": "სხვა დროს მაინც ამოგივლი შე ჩემსავით"
    },
    {
      "start": 265.88,
      "duration": 8.48,
      "text": "მაღალო. მეგრულ მერანს შეუძახა. ასე საით"
    },
    {
      "start": 270.32,
      "duration": 7.76,
      "text": "სწრაფიო იმას კიდე გაუკვირდა ვა ნამდვილი"
    },
    {
      "start": 274.36,
      "duration": 5.36,
      "text": "ჟირაფიო ჭენებაში გაეჯიბრა მოინდომა"
    },
    {
      "start": 278.08,
      "duration": 4.52,
      "text": "გაისარჯა"
    },
    {
      "start": 279.72,
      "duration": 6.759,
      "text": "თუმცა მაინც აქ არ ვიტყვი თუ რომელმა"
    },
    {
      "start": 282.6,
      "duration": 7.76,
      "text": "გაიმარჯვა აფხაზეთში სხვა დროს შევა ისე"
    },
    {
      "start": 286.479,
      "duration": 7.481,
      "text": "იცის უკვე ასეც აფხაზეთიც კუთხე არის"
    },
    {
      "start": 290.36,
      "duration": 7.44,
      "text": "უკეთესი სულ ყველაზე მორჩა სახლში"
    },
    {
      "start": 293.96,
      "duration": 6.76,
      "text": "წამოვიდა თუმც მანამდე რაც კი ნახა"
    },
    {
      "start": 297.8,
      "duration": 5.48,
      "text": "სხვისად არც ცის იგულა და ისიც სახლად"
    },
    {
      "start": 300.72,
      "duration": 6.88,
      "text": "დაისახა. იხსენებდა [მუსიკა]"
    },
    {
      "start": 303.28,
      "duration": 7.68,
      "text": "რა იარა, რა იხილა, რა იცინა,"
    },
    {
      "start": 307.6,
      "duration": 8.12,
      "text": "როგორც იქნა დაიღალა და ამ ფიქრით"
    },
    {
      "start": 310.96,
      "duration": 7.32,
      "text": "ჩაიძინა. ამ მგზავრობამ იმ ჩემს კითხვას"
    },
    {
      "start": 315.72,
      "duration": 6.88,
      "text": "ეს ნათელი მოჰფინაო."
    },
    {
      "start": 318.28,
      "duration": 9.32,
      "text": "სულ ყველაზე უკეთესი საქართველო ყოფილაო."
    },
    {
      "start": 322.6,
      "duration": 10.159,
      "text": "ასე მორჩა ზღაპარი და სად იყო და სად არაო"
    },
    {
      "start": 327.6,
      "duration": 7.24,
      "text": "შენი ძილიც მოფრენილა მეგობარო პატარაო აი"
    },
    {
      "start": 332.759,
      "duration": 4.081,
      "text": "უკვე შემოგხვია სიყვარულის [მუსიკა]"
    },
    {
      "start": 334.84,
      "duration": 11.16,
      "text": "ფრთებიცაო"
    },
    {
      "start": 336.84,
      "duration": 9.16,
      "text": "იავ ნანა ვარდოვ ნანა ტკბილი ძილი ნებისაო"
    },
    {
      "start": 373.72,
      "duration": 2.08,
      "text": "เ"
    },
    {
      "start": 386.454,
      "duration": 2.02,
      "text": ">> [მუსიკა]"
    },
    {
      "start": 393.659,
      "duration": 2.02,
      "text": "[მუსიკა]"
    }
  ]
}